datadoghq.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 257
    forward . 1.1.1.2 1.0.0.2
}

api.anthropic.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN ANY . {
        match "[.]api[.]anthropic[.]com[.]$"
        rcode NXDOMAIN
        fallthrough
    }
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 256
    forward . 1.1.1.2 1.0.0.2
}

somedomain.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 262
    forward . 1.1.1.2 1.0.0.2
}

github.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 259
    forward . 1.1.1.2 1.0.0.2
}

sub.somedomain.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN ANY . {
        rcode NXDOMAIN
    }
}

docker.internal {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 258
    forward . 127.0.0.11
}

otel-collector {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 260
    forward . 127.0.0.11
}

prometheus {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 261
    forward . 127.0.0.11
}

. {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN ANY . {
        rcode NXDOMAIN
    }
    health :18902
    reload 2s
}
