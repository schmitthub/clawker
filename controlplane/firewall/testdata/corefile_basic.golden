github.com {
    otel
    log . "source=coredns client_ip={remote} domain={name} qtype={type} rcode={rcode} duration={duration}"
    template IN ANY . {
        match "[.]github[.]com[.]$"
        rcode NXDOMAIN
        fallthrough
    }
    template IN AAAA . {
        rcode NOERROR
    }
    dnsbpf 261
    forward . 1.1.1.2 1.0.0.2
}

