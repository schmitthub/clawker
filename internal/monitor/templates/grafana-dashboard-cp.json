        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${lokidatasource}" },
          "expr": "{service_name=\"clawker-cp\"} | ingest_source=`cp` |~ \"dockerevents|overseer\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "overseer + dockerevents",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${lokidatasource}" },
      "description": "Warn + Error level only.",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 13 },
