      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${lokidatasource}" },
          "expr": "{service_name=\"clawker-cp\"} | ingest_source=`cp`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "clawker-cp logs",
      "type": "logs"
    },
    {
