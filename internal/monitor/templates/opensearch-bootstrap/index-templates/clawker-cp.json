{
  "index_patterns": ["clawkercp"],
  "priority": 100,
  "composed_of": ["clawker-common"],
  "template": {
    "settings": {
      "index": {
        "default_pipeline": "cp-actor-attr-nest",
        "final_pipeline":   "envelope-normalize"
      }
    },
    "mappings": {
      "properties": {
        "instrumentationScope": {
          "properties": {
            "name":    { "type": "keyword" },
            "version": { "type": "keyword" }
          }
        },
        "attributes": {
          "properties": {
            "event":     { "type": "keyword" },
            "component": { "type": "keyword" },
            "level":     { "type": "keyword" },
            "subsystem": { "type": "keyword" },
            "agent":     { "type": "keyword" },
            "project":   { "type": "keyword" },
            "container": { "type": "keyword" },
            "error":     { "type": "text", "fields": { "keyword": { "type": "keyword", "ignore_above": 1024 } } },
            "actor_attr": { "type": "flat_object" }
          }
        }
      }
    }
  },
  "_meta": {
    "description": "clawkercp zerolog records over mTLS-gated OTLP — scalar attributes.event keyword",
    "managed_by": "clawker-opensearch-bootstrap"
  }
}
