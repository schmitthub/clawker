{
  "index_patterns": ["clawker-envoy"],
  "priority": 100,
  "composed_of": ["clawker-common"],
  "template": {
    "mappings": {
      "properties": {
        "attributes": {
          "properties": {
            "domain":         { "type": "keyword" },
            "proto":          { "type": "keyword" },
            "method":         { "type": "keyword" },
            "path":           { "type": "keyword" },
            "request_host":   { "type": "keyword" },
            "response_code":  { "type": "integer" },
            "response_flags": { "type": "keyword" },
            "client_ip":      { "type": "ip" },
            "upstream_host":  { "type": "keyword" },
            "bytes_sent":     { "type": "long" },
            "bytes_received": { "type": "long" },
            "duration_ms":    { "type": "long" }
          }
        }
      }
    }
  },
  "_meta": {
    "description": "Envoy access logs via native OpenTelemetry ALS — flat HTTP/TLS/TCP fields",
    "managed_by": "clawker-opensearch-bootstrap"
  }
}
