{
  "index_patterns": ["clawker-coredns"],
  "priority": 100,
  "composed_of": ["clawker-common"],
  "template": {
    "settings": {
      "index": {
        "final_pipeline": "envelope-normalize"
      }
    },
    "mappings": {
      "properties": {
        "instrumentationScope": {
          "properties": {
            "name":    { "type": "keyword" },
            "version": { "type": "keyword" }
          }
        },
        "attributes": {
          "properties": {
            "source":       { "type": "keyword" },
            "client_ip":    { "type": "ip" },
            "zone":         { "type": "keyword" },
            "query_name":   { "type": "keyword" },
            "qtype":        { "type": "keyword" },
            "rcode":        { "type": "keyword" },
            "action":       { "type": "keyword" },
            "answer_count": { "type": "integer" },
            "duration_ms":  { "type": "long" },
            "answers":      { "type": "keyword" }
          }
        }
      }
    }
  },
  "_meta": {
    "description": "CoreDNS query records via in-tree otel plugin — structured dns.query attributes",
    "managed_by": "clawker-opensearch-bootstrap"
  }
}
