# Default log rotation for monitoring services. Caps Docker json-file
# growth from the otel-collector debug exporter and any chatty service.
x-default-logging: &default-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "3"

services:
  {{.OtelCollectorService}}:
    container_name: {{.OtelCollectorService}}
    image: {{.OtelCollectorImage}}
    command: ["--config=/etc/otel-collector-config.yaml"]
    deploy:
      resources:
        limits:
          memory: 200M
    restart: unless-stopped
    user: 0:0
    volumes:
      - ./otel-config.yaml:/etc/otel-collector-config.yaml
      # Host root → /hostfs (RO). Feeds the hostmetrics receiver (cpu/
      # mem/disk/network for the underlying host or Docker Desktop VM).
      - {{.HostFilesystem}}:/hostfs:ro
      # Docker daemon socket → /var/run/docker.sock (RO). Feeds the
      # docker_stats receiver. Path-on-host comes from Settings.Docker.Socket.
      - {{.DockerSocketPath}}:/var/run/docker.sock:ro
{{- if .OtelInfraPort}}
      # CLI-issued mTLS material for the CP-only receiver. Bound RO from
      # the CLI auth dir on the host. The CA bundle gates client certs
      # to ones the CLI signed (currently just clawker-cp).
      - {{.OtelServerCertHostPath}}:/etc/otel/tls/server.pem:ro
      - {{.OtelServerKeyHostPath}}:/etc/otel/tls/server.key:ro
      - {{.OtelCAHostPath}}:/etc/otel/tls/ca.pem:ro
{{- end}}
    ports:
      # Existing receivers — published all-interfaces for parity with
      # earlier behaviour. Agent containers push to these via clawker-net
      # DNS (`{{.OtelCollectorService}}:<port>`); host-side debugging uses the
      # published mapping.
      - "{{.OtelGRPCPort}}:{{.OtelGRPCPort}}"
      - "{{.OtelCollectorPort}}:{{.OtelCollectorPort}}"
{{- if .OtelInfraPort}}
      # CP-only receiver — host loopback only. clawker-cp pushes via
      # host.docker.internal:<port>. Agents trying the same address are
      # rejected by BPF (gateway:non-hostproxy → Envoy → reset);
      # additionally, mTLS would refuse them because they have no
      # client cert signed by the CLI CA.
      - "127.0.0.1:{{.OtelInfraPort}}:{{.OtelInfraPort}}"
{{- end}}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      {{.OpenSearchNodeService}}:
        condition: service_started
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"
    networks:
      - clawker-net
    logging: *default-logging

  {{.PrometheusService}}:
    container_name: {{.PrometheusService}}
    image: {{.PrometheusImage}}
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--web.listen-address=:{{.PrometheusPort}}"
      - "--web.enable-remote-write-receiver"
      - "--web.enable-otlp-receiver"
      - "--web.console.templates=/etc/prometheus/consoles"
      - "--web.console.libraries=/etc/prometheus/console_libraries"
      - "--storage.tsdb.path=/prometheus"
      - "--web.enable-lifecycle"
      - "--web.route-prefix=/"
      - "--enable-feature=exemplar-storage"
      - "--enable-feature=otlp-deltatocumulative"
    ports:
      - "127.0.0.1:{{.PrometheusPort}}:{{.PrometheusPort}}"
    volumes:
      - ./prometheus.yaml:/etc/prometheus/prometheus.yml
      - clawker-prometheus:/prometheus
    deploy:
      resources:
        limits:
          memory: 300M
    restart: unless-stopped
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"
    networks:
      - clawker-net
    logging: *default-logging

  {{.OpenSearchNodeService}}:
    container_name: {{.OpenSearchNodeService}}
    image: {{.OpenSearchImage}}
    environment:
      - cluster.name=clawker-observability
      - node.name={{.OpenSearchNodeService}}
      - discovery.type=single-node
      - bootstrap.memory_lock=true
      - DISABLE_SECURITY_PLUGIN=true
      - DISABLE_INSTALL_DEMO_CONFIG=true
      - http.port={{.OpenSearchPort}}
      - "OPENSEARCH_JAVA_OPTS=-Xms{{.OpenSearchHeapMB}}m -Xmx{{.OpenSearchHeapMB}}m"
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "127.0.0.1:{{.OpenSearchPort}}:{{.OpenSearchPort}}"
    volumes:
      - clawker-opensearch:/usr/share/opensearch/data
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"
    networks:
      - clawker-net
    logging: *default-logging

  {{.OpenSearchDashboardsService}}:
    container_name: {{.OpenSearchDashboardsService}}
    image: {{.OpenSearchDashboardsImage}}
    environment:
      - 'OPENSEARCH_HOSTS=["http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"]'
      - DISABLE_SECURITY_DASHBOARDS_PLUGIN=true
      - SERVER_PORT={{.OpenSearchDashboardsPort}}
    ports:
      - "127.0.0.1:{{.OpenSearchDashboardsPort}}:{{.OpenSearchDashboardsPort}}"
    expose:
      - "{{.OpenSearchDashboardsPort}}"
    depends_on:
      - {{.OpenSearchNodeService}}
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"
    networks:
      - clawker-net
    logging: *default-logging

volumes:
  clawker-prometheus:
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"
  clawker-opensearch:
    labels:
      dev.clawker.managed: "true"
      dev.clawker.purpose: "monitoring"

networks:
  clawker-net:
    external: true  # Created by clawker start/run, shared by all clawker services
