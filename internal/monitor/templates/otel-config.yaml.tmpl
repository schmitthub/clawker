receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:{{.OtelGRPCPort}}
      http:
        endpoint: 0.0.0.0:{{.OtelCollectorPort}}
{{- if .OtelCPPort}}
  # mTLS-gated receiver dedicated to clawker-cp. Listens on
  # 0.0.0.0:<port> inside the container; the published mapping in
  # compose.yaml binds the host port to 127.0.0.1 only, so the only
  # off-host way to reach this receiver is via clawker-net DNS — and
  # a TLS handshake with require_client_certificate fails for any
  # peer that wasn't issued a client cert by the CLI CA. Agents on
  # clawker-net therefore can't push here even if they try.
  otlp/cp:
    protocols:
      http:
        endpoint: 0.0.0.0:{{.OtelCPPort}}
        tls:
          cert_file: /etc/otel/tls/server.pem
          key_file: /etc/otel/tls/server.key
          client_ca_file: /etc/otel/tls/ca.pem
{{- end}}

processors:
  batch:
  # Copy project/agent from resource attributes to datapoint attributes.
  # The Prometheus exporter only surfaces datapoint attributes as metric labels,
  # so this transform is required for per-project/agent filtering in Grafana.
  transform/metrics:
    metric_statements:
      - context: datapoint
        statements:
          - set(attributes["project"], resource.attributes["project"]) where resource.attributes["project"] != nil
          - set(attributes["agent"], resource.attributes["agent"]) where resource.attributes["agent"] != nil
  # Provenance stamp for agent-side telemetry. Runs AFTER the otlp
  # receiver and force-sets ingest_source=agent regardless of what the
  # client sent. service.name is NOT normalized here so per-component
  # granularity (claude-code, envoy, coredns, ...) is preserved; the
  # trustable provenance signal is ingest_source, which the agent
  # cannot fake because this processor unconditionally upserts it
  # post-receiver. A spoofed service.name=clawker-cp on the agent
  # plaintext path still lands with ingest_source=agent.
  resource/agent:
    attributes:
      - key: ingest_source
        value: agent
        action: upsert
{{- if .OtelCPPort}}
  # Provenance stamp for clawker-cp telemetry. Reaches this processor
  # only via the mTLS-gated otlp/cp receiver (CLI-issued client cert
  # required at TLS handshake — agents on clawker-net have none and
  # are rejected before bytes flow). Both service.name and
  # ingest_source are forced regardless of what the client sent so
  # CP-shaped logs cannot be forged from the unauth'd agent receiver.
  resource/cp:
    attributes:
      - key: ingest_source
        value: cp
        action: upsert
      - key: service.name
        value: clawker-cp
        action: upsert
{{- end}}

exporters:
  # Traces → OpenSearch (Simple Schema for Observability data model).
  opensearch/traces:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:9200"
    dataset: traces
    namespace: clawker
  # Logs → OpenSearch. Single index for both agent and CP streams;
  # ingest_source attribute distinguishes them at query time.
  opensearch/logs:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:9200"
    logs_index: clawker-logs
  # Metrics → Prometheus scrape endpoint.
  prometheus:
    endpoint: "0.0.0.0:{{.PrometheusMetricsPort}}"

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [opensearch/traces]
    metrics:
      receivers: [otlp]
      processors: [batch, transform/metrics]
      exporters: [prometheus]
    # Agent-side logs pipeline: receiver-isolated from the CP pipeline.
    # An agent pushing here cannot reach the otlp/cp receiver
    # (mTLS-gated) and cannot get its log stamped ingest_source=cp —
    # resource/agent runs unconditionally and overwrites the field.
    logs/agents:
      receivers: [otlp]
      processors: [resource/agent, batch]
      exporters: [opensearch/logs]
{{- if .OtelCPPort}}
    # CP-side logs pipeline: separate receiver, separate processor
    # chain. service.name and ingest_source are both forced post-
    # receiver so a malicious cert holder (none exist outside CLI
    # provisioning) still couldn't shadow agent telemetry.
    logs/cp:
      receivers: [otlp/cp]
      processors: [resource/cp, batch]
      exporters: [opensearch/logs]
{{- end}}
