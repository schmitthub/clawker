receivers:
  # Untrusted OTLP ingress for agent containers (Claude Code's SDK).
  # No client auth — agent on clawker-net can reach this. Records are
  # dispatched by routing/untrusted which only forwards service.name=
  # claude-code; everything else is dropped. service.name=envoy/coredns/
  # clawker-cp from this receiver can NOT route to the trusted indices.
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:{{.OtelGRPCPort}}
      http:
        endpoint: 0.0.0.0:{{.OtelCollectorPort}}
{{- if .OtelInfraPort}}
  # Trusted OTLP ingress, gated by mTLS. Listens on 0.0.0.0:<port>
  # inside the container; the published mapping in compose.yaml binds
  # the host port to 127.0.0.1 only. Agents on clawker-net can reach
  # this port over the docker network, but the TLS handshake rejects
  # any peer without a client cert chained to the CLI root CA — only
  # CP (CLI-direct cp-client cert) and infra services (envoy/coredns,
  # intermediate-signed via internal/controlplane/infracerts) have one.
  #
  # service.name on records that arrive here is trusted by virtue of
  # mTLS having succeeded. routing/trusted dispatches by service.name
  # to cp/envoy/coredns pipelines. The downstream resource/* processors
  # stamp ingest_source for cross-index queries; they do NOT overwrite
  # service.name (a compromised infra service is already game-over for
  # its own log lane, no extra defense to add here).
  otlp/infra:
    protocols:
      grpc:
        endpoint: 0.0.0.0:{{.OtelInfraPort}}
        tls:
          cert_file: /etc/otel/tls/server.pem
          key_file: /etc/otel/tls/server.key
          client_ca_file: /etc/otel/tls/ca.pem
          # client_ca_file alone configures a trust pool but does NOT
          # require peers to present a cert; agents on clawker-net would
          # land in the trusted lane with no auth. require_client_auth=true
          # makes the handshake fail when no client cert is presented.
          require_client_auth: true
{{- end}}
  # Collector self-telemetry. The otel-collector exposes its own
  # process/pipeline metrics as a Prometheus endpoint on :8888 by
  # default; scraping them here lets the metrics pipeline ship them
  # downstream to the same Prometheus instance operators already use.
  prometheus/self:
    config:
      scrape_configs:
        - job_name: 'otelcol'
          scrape_interval: 10s
          static_configs:
            - targets: ['0.0.0.0:8888']
  # Container-level metrics scraped from the Docker daemon. Reads via
  # the RO-mounted socket at /var/run/docker.sock (compose maps host
  # Settings.Docker.Socket → this path).
  docker_stats:
    endpoint: unix:///var/run/docker.sock
    collection_interval: 10s
  # Host metrics for the machine running the otel-collector. On Linux
  # this is the actual host; on Docker Desktop it's the Linux VM (the
  # constraint operators care about). Reads via the RO-mounted host
  # root at /hostfs.
  hostmetrics:
    root_path: /hostfs
    scrapers:
      cpu:
        metrics:
          system.cpu.utilization:
            enabled: true
      disk:
      load:
      filesystem:
        exclude_mount_points:
          mount_points:
            - /dev/*
            - /proc/*
            - /sys/*
            - /run/k3s/containerd/*
            - /var/lib/docker/*
            - /var/lib/kubelet/*
            - /snap/*
          match_type: regexp
        exclude_fs_types:
          fs_types:
            - autofs
            - binfmt_misc
            - bpf
            - cgroup2
            - configfs
            - debugfs
            - devpts
            - devtmpfs
            - fusectl
            - hugetlbfs
            - iso9660
            - mqueue
            - nsfs
            - overlay
            - proc
            - procfs
            - pstore
            - rpc_pipefs
            - securityfs
            - selinuxfs
            - squashfs
            - sysfs
            - tracefs
          match_type: strict
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      network:
      paging:
      processes:
      process:
        mute_process_exe_error: true
        mute_process_io_error: true
        mute_process_user_error: true

processors:
  batch:
  # Copy project/agent from resource attributes to datapoint attributes.
  # The Prometheus exporter only surfaces datapoint attributes as metric labels,
  # so this transform is required for per-project/agent filtering in Grafana.
  transform/metrics:
    metric_statements:
      - context: datapoint
        statements:
          - set(attributes["project"], resource.attributes["project"]) where resource.attributes["project"] != nil
          - set(attributes["agent"], resource.attributes["agent"]) where resource.attributes["agent"] != nil
{{- if .OtelInfraPort}}
  # Provenance stamps. Each trusted source gets ingest_source=<name>
  # so cross-index queries can filter on a single field. service.name
  # is NOT overwritten — mTLS handshake authenticated the sender;
  # whatever they declared is trusted.
  resource/cp:
    attributes:
      - key: ingest_source
        value: cp
        action: upsert
  resource/envoy:
    attributes:
      - key: ingest_source
        value: envoy
        action: upsert
  resource/coredns:
    attributes:
      - key: ingest_source
        value: coredns
        action: upsert
{{- end}}

exporters:
  # Stdout pipe-through for diagnosis. Surfaces in `docker logs
  # clawker-otel-collector`; verbose by design.
  debug:
  # Traces → OpenSearch (Simple Schema for Observability data model).
  opensearch/traces:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    dataset: traces
    namespace: clawker
  # Logs → OpenSearch. Indices split by source so dynamic mappings
  # don't collide. clawker emits attributes.event as a scalar string
  # (logger pattern `Str("event", ...)`); Claude Code emits the OTEL
  # semantic-conventions nested form `event.name`. Sharing one index
  # locks first-seen shape and rejects the other source — split keeps
  # each schema clean.
  opensearch/logs_cp:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-cp
  opensearch/logs_claude_code:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: claude-code
  opensearch/logs_envoy:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-envoy
  opensearch/logs_coredns:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-coredns
  # Metrics → Prometheus scrape endpoint.
  prometheus:
    endpoint: "0.0.0.0:{{.PrometheusMetricsPort}}"

connectors:
  # Derives RED metrics (rate, errors, duration) from spans flowing
  # through the traces pipeline and re-emits them into the metrics
  # pipeline. Empty-series until traces actually flow.
  spanmetrics:
  # Route untrusted (plaintext OTLP) records. Only claude-code records
  # land in their index; everything else is silently dropped (no
  # default_pipelines). An agent crafting `service.name=envoy` from
  # the unauth'd port CANNOT reach the clawker-envoy index — there is
  # no envoy route off this connector.
  routing/untrusted:
    error_mode: ignore
    table:
      - context: resource
        condition: attributes["service.name"] == "claude-code"
        pipelines: [logs/claude-code]
{{- if .OtelInfraPort}}
  # Route trusted (mTLS-gated) records by sender-declared service.name.
  # Reachable only by peers with a CLI-root-chained client cert.
  routing/trusted:
    error_mode: ignore
    table:
      - context: resource
        condition: attributes["service.name"] == "clawker-cp"
        pipelines: [logs/cp]
      - context: resource
        condition: attributes["service.name"] == "envoy"
        pipelines: [logs/envoy]
      - context: resource
        condition: attributes["service.name"] == "coredns"
        pipelines: [logs/coredns]
{{- end}}

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [opensearch/traces, spanmetrics, debug]
    metrics:
      receivers: [otlp, prometheus/self, docker_stats, hostmetrics, spanmetrics]
      processors: [batch, transform/metrics]
      exporters: [prometheus, debug]
    # Untrusted log ingress. Only claude-code routes downstream; other
    # service.name values are dropped at the routing connector.
    logs/in_untrusted:
      receivers: [otlp]
      processors: [batch]
      exporters: [routing/untrusted]
    logs/claude-code:
      receivers: [routing/untrusted]
      processors: []
      exporters: [opensearch/logs_claude_code, debug]
{{- if .OtelInfraPort}}
    # Trusted log ingress. mTLS handshake is the auth boundary; the
    # routing connector dispatches by sender-declared service.name to
    # the right index. resource/* processors only stamp ingest_source
    # for cross-index query convenience.
    logs/in_trusted:
      receivers: [otlp/infra]
      processors: [batch]
      exporters: [routing/trusted]
    logs/cp:
      receivers: [routing/trusted]
      processors: [resource/cp]
      exporters: [opensearch/logs_cp, debug]
    logs/envoy:
      receivers: [routing/trusted]
      processors: [resource/envoy]
      exporters: [opensearch/logs_envoy, debug]
    logs/coredns:
      receivers: [routing/trusted]
      processors: [resource/coredns]
      exporters: [opensearch/logs_coredns, debug]
{{- end}}
