receivers:
  # Untrusted OTLP ingress for agent containers (Claude Code's SDK) +
  # host CLI (clawker-cli). No client auth — anyone reachable on
  # clawker-net or the host loopback can push. Records are dispatched
  # by routing/untrusted, which forwards only service.name=claude-code
  # and service.name=clawker-cli to their respective indices; every
  # other service.name (including spoofed envoy/coredns/clawker-cp) is
  # dropped at routing. The resource/untrusted_otlp processor stamps
  # ingest_source=untrusted_otlp on all records from this receiver so
  # dashboards can separate forgeable, sender-declared records from
  # provenance-stamped ones.
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:{{.OtelGRPCPort}}
      http:
        endpoint: 0.0.0.0:{{.OtelCollectorPort}}
  # Trusted OTLP ingress, gated by mTLS. Listens on 0.0.0.0:<port>
  # inside the container; the published mapping in compose.yaml binds
  # the host port to 127.0.0.1 only. Agents on clawker-net can reach
  # this port over the docker network, but the TLS handshake rejects
  # any peer whose client cert chain does not validate against the
  # infra intermediate CA — only CP and infra services (envoy/coredns,
  # cp) hold leaves signed by that intermediate.
  #
  # Trust anchor is the infra intermediate CA, NOT the CLI root. Agent
  # containers carry leaves signed directly by the CLI root with no
  # path through the intermediate, so their chain fails validation
  # even when they present a valid CLI-signed cert.
  #
  # service.name on records that arrive here is trusted by virtue of
  # mTLS having succeeded. routing/trusted dispatches by service.name
  # to cp/envoy/coredns pipelines. The downstream resource/* processors
  # stamp ingest_source for cross-index queries; they do NOT overwrite
  # service.name (a compromised infra service is already game-over for
  # its own log lane, no extra defense to add here).
  otlp/infra:
    protocols:
      grpc:
        endpoint: 0.0.0.0:{{.OtelInfraPort}}
        tls:
          cert_file: /etc/otel/tls/server.pem
          key_file: /etc/otel/tls/server.key
          # Setting client_ca_file forces tls.RequireAndVerifyClientCert
          # in configtls.ServerConfig.LoadTLSConfig — handshake fails
          # when no client cert is presented or when the presented
          # chain does not validate against this CA. Bind-mount source
          # is consts.AuthInfraCACertPath() — the infra intermediate.
          client_ca_file: /etc/otel/tls/ca.pem
  # Collector self-telemetry. The otel-collector exposes its own
  # process/pipeline metrics as a Prometheus endpoint on :8888 by
  # default; scraping them here lets the metrics pipeline ship them
  # downstream to the same Prometheus instance operators already use.
  prometheus/self:
    config:
      scrape_configs:
        - job_name: 'otelcol'
          scrape_interval: 10s
          static_configs:
            - targets: ['127.0.0.1:8888']
  # Container-level metrics scraped from the Docker daemon. Reads via
  # the RO-mounted socket at /var/run/docker.sock (compose maps host
  # Settings.Docker.Socket → this path).
  docker_stats:
    endpoint: unix:///var/run/docker.sock
    collection_interval: 10s
  # Host metrics for the machine running the otel-collector. On Linux
  # this is the actual host; on Docker Desktop it's the Linux VM (the
  # constraint operators care about). Reads via the RO-mounted host
  # root at /hostfs.
  hostmetrics:
    root_path: /hostfs
    scrapers:
      cpu:
        metrics:
          system.cpu.utilization:
            enabled: true
      disk:
      load:
      filesystem:
        exclude_mount_points:
          mount_points:
            - /dev/*
            - /proc/*
            - /sys/*
            - /run/k3s/containerd/*
            - /var/lib/docker/*
            - /var/lib/kubelet/*
            - /snap/*
          match_type: regexp
        exclude_fs_types:
          fs_types:
            - autofs
            - binfmt_misc
            - bpf
            - cgroup2
            - configfs
            - debugfs
            - devpts
            - devtmpfs
            - fusectl
            - hugetlbfs
            - iso9660
            - mqueue
            - nsfs
            - overlay
            - proc
            - procfs
            - pstore
            - rpc_pipefs
            - securityfs
            - selinuxfs
            - squashfs
            - sysfs
            - tracefs
          match_type: strict
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      network:
      paging:
      processes:
      process:
        mute_process_exe_error: true
        mute_process_io_error: true
        mute_process_user_error: true

processors:
  # Cap collector memory below the 200M compose hard limit so burst
  # load applies backpressure rather than triggering an OOM-kill. Must
  # be the first processor in every pipeline to be effective.
  memory_limiter:
    check_interval: 1s
    limit_mib: 150
    spike_limit_mib: 30
  # Explicit batch sizing so behavior is predictable under burst. The
  # 5s timeout keeps forensic indices reasonably near-real-time without
  # over-shipping tiny batches at low volume.
  batch:
    timeout: 5s
    send_batch_size: 1024
    send_batch_max_size: 2048
  # Provenance stamp for everything entering on the unauth'd otlp
  # receiver. Lets queries trivially separate forgeable
  # sender-declared records from records whose source is anchored by
  # mTLS handshake. Applied at the start of every untrusted-lane
  # pipeline; service.name itself is left alone so routing can still
  # dispatch on it.
  resource/untrusted_otlp:
    attributes:
      - key: ingest_source
        value: untrusted_otlp
        action: upsert
  # Copy project/agent from resource attributes to datapoint attributes.
  # The Prometheus exporter only surfaces datapoint attributes as metric labels,
  # so this transform is required for per-project/agent filtering on the
  # scraped Prometheus series (and any UI built on top — OpenSearch Dashboards
  # Observability Metrics, Prometheus UI, etc.).
  # error_mode: ignore so a single malformed datapoint (e.g. an SDK that
  # emits resource.attributes["project"] as a slice instead of scalar)
  # drops the offending point rather than killing the pipeline silently.
  # OTTL errors surface in collector stdout via the default INFO log level.
  transform/metrics:
    error_mode: ignore
    metric_statements:
      - context: datapoint
        statements:
          - set(attributes["project"], resource.attributes["project"]) where resource.attributes["project"] != nil
          - set(attributes["agent"], resource.attributes["agent"]) where resource.attributes["agent"] != nil
  # Convert delta-temporality Sum metrics into cumulative before they hit
  # the Prometheus exporter. Claude Code's SDK emits its counters
  # (claude_code.cost.usage, claude_code.token.usage, etc.) with
  # AggregationTemporality=Delta — each export is the increment since the
  # last export, not the running total. The Prometheus exporter requires
  # cumulative semantics for `_total` series; without this processor, each
  # scrape sees only the latest delta instead of the lifetime sum, which
  # silently undercounts every Claude Code counter by 10-20× over a session.
  # Spanmetrics-derived RED metrics on the trusted pipeline are also delta
  # by default, so apply on both metrics pipelines.
  deltatocumulative:
    max_streams: 10000
    max_stale: 5m
  # Provenance stamps. Each trusted source gets ingest_source=<name>
  # so cross-index queries can filter on a single field. service.name
  # is NOT overwritten — mTLS handshake authenticated the sender;
  # whatever they declared is trusted.
  resource/cp:
    attributes:
      - key: ingest_source
        value: cp
        action: upsert
  resource/envoy:
    attributes:
      - key: ingest_source
        value: envoy
        action: upsert
  resource/coredns:
    attributes:
      - key: ingest_source
        value: coredns
        action: upsert

exporters:
  # Stdout pipe-through for diagnosis. Surfaces in `docker logs
  # clawker-otel-collector`; verbose by design.
  debug:
    verbosity: detailed
  # Traces → OpenSearch (Simple Schema for Observability data model).
  # sending_queue + retry_on_failure keep batches alive across the
  # OpenSearch startup window and short outages so forensic data
  # isn't dropped silently.
  opensearch/traces:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    dataset: traces
    namespace: clawker
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  # Logs → OpenSearch. Indices split by source because each source has
  # a different schema shape: clawker emits attributes.event as a scalar
  # string (logger pattern `Str("event", ...)`); Claude Code emits the
  # OTEL semantic-conventions nested form `event.name`; Envoy ALS lands
  # HTTP/TLS/TCP fields flat on the record; the CoreDNS otel plugin
  # emits structured dns.query attributes. The clawker-opensearch-bootstrap
  # one-shot service PUTs an explicit index template per source (see
  # templates/opensearch-bootstrap/index-templates/) BEFORE the collector
  # starts — its compose `depends_on: service_completed_successfully` on
  # bootstrap is what guarantees that ordering — so each schema is locked
  # at index creation by the template, not raced by first-ingest dynamic
  # mapping. sending_queue + retry_on_failure protect against OpenSearch
  # unavailability windows (boot, GC pause, indexing pressure) where
  # dropping forensic records would be the worst time.
  opensearch/logs_cp:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-cp
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  opensearch/logs_claude_code:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: claude-code
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  opensearch/logs_clawker_cli:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-cli
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  opensearch/logs_envoy:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-envoy
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  opensearch/logs_coredns:
    http:
      endpoint: "http://{{.OpenSearchNodeService}}:{{.OpenSearchPort}}"
    logs_index: clawker-coredns
    sending_queue:
      enabled: true
    retry_on_failure:
      enabled: true
      initial_interval: 5s
      max_elapsed_time: 5m
  # Metrics → Prometheus scrape endpoint. Pull-based, so no retry
  # config — Prometheus handles its own scrape cadence.
  #
  # metric_expiration controls the exporter's staleness window. The
  # default (5m) reaps cumulative counters that haven't seen a fresh
  # delta in 5 minutes. Several Claude Code counters fire only on
  # user-action triggers (session.count, code_edit_tool.decision,
  # commit.count, pull_request.count, lines_of_code.count) — gaps of
  # hours between deltas are normal, and the default expiration would
  # silently drop them from `_total` series after their last event.
  # Foot-gun: `0` does NOT disable expiration — it expires every
  # metric on every Collect call. Use a long duration instead. The
  # stack is throwaway (`monitor down --volumes` is the reset), so
  # one year is "effectively never."
  prometheus:
    endpoint: "0.0.0.0:{{.PrometheusMetricsPort}}"
    metric_expiration: 8760h

connectors:
  # Derives RED metrics (rate, errors, duration) from spans flowing
  # through the traces pipeline and re-emits them into the metrics
  # pipeline. Empty-series until traces actually flow.
  spanmetrics:
  # Route untrusted (plaintext OTLP) records. Only claude-code and
  # clawker-cli records reach their indices. An agent crafting
  # `service.name=envoy`/`coredns`/`clawker-cp` from the unauth'd
  # port CANNOT reach the trusted indices — there is no such route
  # off this connector. default_pipelines catches any other
  # service.name (e.g. SDK default `unknown_service`, a misconfigured
  # local script) and routes it to logs/untrusted_unrouted where it
  # surfaces in collector stdout for debugging — not indexed, since
  # the records are forgeable.
  routing/untrusted:
    error_mode: ignore
    default_pipelines: [logs/untrusted_unrouted]
    table:
      - context: resource
        condition: attributes["service.name"] == "claude-code"
        pipelines: [logs/claude-code]
      - context: resource
        condition: attributes["service.name"] == "clawker-cli"
        pipelines: [logs/clawker-cli]
  # Route trusted (mTLS-gated) records by sender-declared service.name.
  # Reachable only by peers whose client cert chains through the infra
  # intermediate CA. error_mode: propagate so OTTL evaluation errors
  # on legitimate forensic records surface in collector logs rather
  # than being silently swallowed. default_pipelines catches any
  # unmapped service.name and routes it to logs/trusted_unrouted —
  # operator can grep collector stdout if this fires (it shouldn't,
  # only cp/envoy/coredns hold infra-intermediate leaves today).
  routing/trusted:
    error_mode: propagate
    default_pipelines: [logs/trusted_unrouted]
    table:
      - context: resource
        condition: attributes["service.name"] == "clawker-cp"
        pipelines: [logs/cp]
      - context: resource
        condition: attributes["service.name"] == "envoy"
        pipelines: [logs/envoy]
      - context: resource
        condition: attributes["service.name"] == "coredns"
        pipelines: [logs/coredns]

service:
  pipelines:
    # Untrusted traces — agent-pushed spans. resource/untrusted_otlp
    # stamps every record so dashboards can separate forgeable
    # sender-declared spans from trusted-lane spans (currently none,
    # but the pattern extends cleanly when a trusted span source is
    # added).
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resource/untrusted_otlp, batch]
      exporters: [opensearch/traces, spanmetrics, debug]
    # Untrusted metrics — anything arriving on the unauth'd otlp
    # receiver. transform/metrics copies project/agent resource attrs
    # to datapoint labels; ingest_source=untrusted_otlp is stamped
    # first so the forgeable labels are always paired with the
    # provenance marker.
    metrics/untrusted:
      receivers: [otlp]
      processors: [memory_limiter, resource/untrusted_otlp, transform/metrics, deltatocumulative, batch]
      exporters: [prometheus, debug]
    # Trusted metrics — collector self-scrape, docker_stats,
    # hostmetrics, and spanmetrics-derived RED metrics. All sourced
    # locally; no sender-declared resource attrs to defend.
    metrics/trusted:
      receivers: [prometheus/self, docker_stats, hostmetrics, spanmetrics]
      processors: [memory_limiter, transform/metrics, deltatocumulative, batch]
      exporters: [prometheus, debug]
    # Untrusted log ingress. Only claude-code/clawker-cli route
    # downstream; other service.name values are dropped at the routing
    # connector. ingest_source stamped here so it carries through to
    # the per-source pipelines.
    logs/in_untrusted:
      receivers: [otlp]
      processors: [memory_limiter, resource/untrusted_otlp, batch]
      exporters: [routing/untrusted]
    logs/claude-code:
      receivers: [routing/untrusted]
      processors: [memory_limiter]
      exporters: [opensearch/logs_claude_code, debug]
    logs/clawker-cli:
      receivers: [routing/untrusted]
      processors: [memory_limiter]
      exporters: [opensearch/logs_clawker_cli, debug]
    # Quarantine for untrusted records whose service.name isn't
    # claude-code or clawker-cli. Stdout-only (debug); never indexed
    # because the lane is unauthenticated and the records are
    # forgeable. Operator can grep `docker logs clawker-otel-collector`
    # for the dropped record to spot a misconfigured sender.
    logs/untrusted_unrouted:
      receivers: [routing/untrusted]
      processors: [memory_limiter]
      exporters: [debug]
    # Trusted log ingress. mTLS handshake is the auth boundary; the
    # routing connector dispatches by sender-declared service.name to
    # the right index. resource/* processors only stamp ingest_source
    # for cross-index query convenience.
    logs/in_trusted:
      receivers: [otlp/infra]
      processors: [memory_limiter, batch]
      exporters: [routing/trusted]
    logs/cp:
      receivers: [routing/trusted]
      processors: [memory_limiter, resource/cp]
      exporters: [opensearch/logs_cp, debug]
    logs/envoy:
      receivers: [routing/trusted]
      processors: [memory_limiter, resource/envoy]
      exporters: [opensearch/logs_envoy, debug]
    logs/coredns:
      receivers: [routing/trusted]
      processors: [memory_limiter, resource/coredns]
      exporters: [opensearch/logs_coredns, debug]
    # Quarantine for any trusted-lane record with an unmapped
    # service.name. Should never fire — only cp/envoy/coredns hold
    # infra-intermediate-chained leaves today. If it does, operator
    # can grep `docker logs clawker-otel-collector` for the debug
    # output to identify a misconfigured trusted sender.
    logs/trusted_unrouted:
      receivers: [routing/trusted]
      processors: [memory_limiter]
      exporters: [debug]
