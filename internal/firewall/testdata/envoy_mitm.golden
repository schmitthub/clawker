admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - cluster_type:
            name: envoy.clusters.dynamic_forward_proxy
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.clusters.dynamic_forward_proxy.v3.ClusterConfig
                dns_cache_config:
                    dns_lookup_family: V4_ONLY
                    name: dynamic_forward_proxy_cache_config
          connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: dynamic_forward_proxy_cluster
        - connect_timeout: 1s
          load_assignment:
            cluster_name: deny_cluster
            endpoints: []
          name: deny_cluster
          type: STATIC
    listeners:
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 10000
          filter_chains:
            - filter_chain_match:
                server_names:
                    - api.openai.com
              filters:
                - name: envoy.filters.network.http_connection_manager
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                    codec_type: AUTO
                    http_filters:
                        - name: envoy.filters.http.dynamic_forward_proxy
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.dynamic_forward_proxy.v3.FilterConfig
                            dns_cache_config:
                                dns_lookup_family: V4_ONLY
                                name: dynamic_forward_proxy_cache_config
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    route_config:
                        name: mitm_route_api_openai_com
                        virtual_hosts:
                            - domains:
                                - '*'
                              name: api.openai.com
                              routes:
                                - match:
                                    prefix: /v1/chat
                                  route:
                                    cluster: dynamic_forward_proxy_cluster
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Blocked by clawker firewall
                                    status: 403
                                  match:
                                    prefix: /v1/admin
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Blocked by clawker firewall
                                    status: 403
                                  match:
                                    prefix: /
                    stat_prefix: mitm_api_openai_com
              transport_socket:
                name: envoy.transport_sockets.tls
                typed_config:
                    '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.DownstreamTlsContext
                    common_tls_context:
                        tls_certificates:
                            - certificate_chain:
                                filename: /etc/envoy/certs/api.openai.com-cert.pem
                              private_key:
                                filename: /etc/envoy/certs/api.openai.com-key.pem
            - filter_chain_match:
                server_names:
                    - storage.googleapis.com
              filters:
                - name: envoy.filters.network.http_connection_manager
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                    codec_type: AUTO
                    http_filters:
                        - name: envoy.filters.http.dynamic_forward_proxy
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.dynamic_forward_proxy.v3.FilterConfig
                            dns_cache_config:
                                dns_lookup_family: V4_ONLY
                                name: dynamic_forward_proxy_cache_config
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    route_config:
                        name: mitm_route_storage_googleapis_com
                        virtual_hosts:
                            - domains:
                                - '*'
                              name: storage.googleapis.com
                              routes:
                                - match:
                                    prefix: /download/
                                  route:
                                    cluster: dynamic_forward_proxy_cluster
                                - match:
                                    prefix: /
                                  route:
                                    cluster: dynamic_forward_proxy_cluster
                    stat_prefix: mitm_storage_googleapis_com
              transport_socket:
                name: envoy.transport_sockets.tls
                typed_config:
                    '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.DownstreamTlsContext
                    common_tls_context:
                        tls_certificates:
                            - certificate_chain:
                                filename: /etc/envoy/certs/storage.googleapis.com-cert.pem
                              private_key:
                                filename: /etc/envoy/certs/storage.googleapis.com-key.pem
            - filter_chain_match: {}
              filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    cluster: deny_cluster
                    stat_prefix: deny_all
          listener_filters:
            - name: envoy.filters.listener.tls_inspector
              typed_config:
                '@type': type.googleapis.com/envoy.extensions.filters.listener.tls_inspector.v3.TlsInspector
          name: tls_egress
