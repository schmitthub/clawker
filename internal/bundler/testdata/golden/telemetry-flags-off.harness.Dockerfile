# Generated by Clawker - harness image for 2.99.99-test FROM clawker-test:base
#
# Harness half of the image split: template blocks, harness volume dirs,
# config seeds, and the clawker-managed root assets. Builds FROM the
# per-project shared base image (see Dockerfile.base.tmpl) — keep the
# shared sections of the two templates in sync when editing.

# Builder stage for callback-forwarder
FROM golang:1.25.10-alpine@sha256:8d22e29d960bc50cd025d93d5b7c7d220b1ee9aa7a239b3c8f55a57e987e8d45 AS callback-forwarder-builder
WORKDIR /build
COPY callback-forwarder.go .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o callback-forwarder callback-forwarder.go

# Builder stage for clawker-socket-server (unified socket forwarding)
FROM golang:1.25.10-alpine@sha256:8d22e29d960bc50cd025d93d5b7c7d220b1ee9aa7a239b3c8f55a57e987e8d45 AS socket-server-builder
WORKDIR /build
COPY clawker-socket-server.go .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o clawker-socket-server clawker-socket-server.go

FROM clawker-test:base AS final

# The base image's config ends at the zsh SHELL with the unprivileged user
# active; ARGs do not survive FROM. Restore the standard per-block
# semantics: root_after_stacks and user_after_stacks run under /bin/sh,
# user_after_shell_switch onward under zsh; root_after_stacks runs as root.
SHELL ["/bin/sh", "-c"]
ARG USERNAME=clawker
USER root


# Node.js (≥22.10) trusts the OS CA bundle. Set globally — applies to root
# (build-time RUN steps) AND to the unprivileged user (agent hooks, user
# `npm`/`npx`). When the firewall MITM CA is added to /etc/ssl/certs via
# update-ca-certificates (clawker's late root block), `fetch()` and TLS
# calls from any process transparently trust clawker's interception cert.
ENV NODE_USE_SYSTEM_CA=1

# Root-global Node.js on /usr/local — resolves from ${PATH} for build-time
# RUN steps, agent tooling, and interactive shells alike.
#
# NODE_VERSION names the LTS *line* (e.g. "24"), not an exact patch; the latest
# patch in that line is resolved per-build from nodejs.org/dist/index.json so
# rebuilds float forward onto security patches (dep-rot rationale:
# docs/threat-model.mdx). The prebuilt tarball is GPG-verified via
# SHASUMS256.txt.asc. Guarded: an image that already provides node at major
# >= NODE_MIN_MAJOR keeps its own install — a deliberate user choice is never
# overwritten; below the floor (too old for NODE_USE_SYSTEM_CA et al.) the
# clawker install lands on /usr/local and wins PATH.
ARG NODE_VERSION=24
ARG NODE_MIN_MAJOR=22
RUN if command -v node >/dev/null 2>&1 && [ "$(node -e 'console.log(process.versions.node.split(".")[0])')" -ge "${NODE_MIN_MAJOR}" ]; then \
      echo "clawker stack node: existing $(node --version) satisfies floor ${NODE_MIN_MAJOR} — skipping install"; \
    else \
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates dirmngr xz-utils libatomic1 && \
    NODE_LTS_VERSION=$(curl -sSfL https://nodejs.org/dist/index.json | jq -r --arg ver "$NODE_VERSION" '[.[] | select(.lts != false)] | map(select(.version | startswith("v" + $ver + "."))) | .[0].version' | sed 's/^v//') && \
    { [ -n "$NODE_LTS_VERSION" ] && [ "$NODE_LTS_VERSION" != "null" ]; } || { echo "ERROR: could not resolve Node LTS line ${NODE_VERSION}" >&2; exit 1; } && \
    ARCH= && dpkgArch="$(dpkg --print-architecture)" && \
    case "${dpkgArch##*-}" in \
      amd64) ARCH='x64' ;; \
      arm64) ARCH='arm64' ;; \
      *) echo "ERROR: node prebuilt does not support architecture: $dpkgArch (only amd64 and arm64)" >&2; exit 1 ;; \
    esac && \
    set -ex && \
    export GNUPGHOME="$(mktemp -d)" && \
    for key in \
      5BE8A3F6C8A5C01D106C0AD820B1A390B168D356 \
      DD792F5973C6DE52C432CBDAC77ABFA00DDBF2B7 \
      CC68F5A3106FF448322E48ED27F5E38D5B0A215F \
      8FCCA13FEF1D0C2E91008E09770F7A9A5AE15600 \
      890C08DB8579162FEE0DF9DB8BEAB4DFCF555EF4 \
      C82FA3AE1CBEDC6BE46B9360C43CEC45C17AB93C \
      108F52B48DB57BB0CC439B2997B01419BD92F80A \
      A363A499291CBBC940DD62E41F10027AF002F8B0 \
    ; do \
      { gpg --batch --keyserver hkps://keys.openpgp.org --recv-keys "$key" && gpg --batch --fingerprint "$key"; } || \
      { gpg --batch --keyserver keyserver.ubuntu.com --recv-keys "$key" && gpg --batch --fingerprint "$key"; } ; \
    done && \
    curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" && \
    curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/SHASUMS256.txt.asc" && \
    gpg --batch --decrypt --output SHASUMS256.txt SHASUMS256.txt.asc && \
    gpgconf --kill all && \
    rm -rf "$GNUPGHOME" && \
    grep " node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz\$" SHASUMS256.txt | sha256sum -c - && \
    tar -xJf "node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" -C /usr/local --strip-components=1 --no-same-owner && \
    rm "node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" SHASUMS256.txt.asc SHASUMS256.txt && \
    ln -s /usr/local/bin/node /usr/local/bin/nodejs && \
    node --version && npm --version ; \
    fi

# TypeScript, baked root-global into npm's system prefix. Root-global (not an
# nvm-scope install) so `tsc` stays on PATH across nvm version switches — its
# `env node` shebang runs whichever node is active. Floated to latest for the
# same dep-rot rationale as the node install above. Guarded: an image that
# already provides tsc keeps its own — a deliberate user pin is never
# overwritten (users can also shadow it per-version via nvm's npm).
RUN if command -v tsc >/dev/null 2>&1; then \
      echo "clawker stack node: existing tsc $(tsc --version) — skipping typescript install"; \
    else \
      npm install -g typescript && tsc --version; \
    fi

# Managed enterprise settings (Linux managed path, highest precedence,
# cannot be overridden by user/project settings). REQUIRED — do not
# remove. Claude Code's Bash tool runs `/bin/zsh -c` and sources its own
# shell snapshot AFTER zsh init files, so the snapshot's PATH overrides
# anything `.zshenv` exports; managed-settings.json is the only documented
# enterprise mechanism that injects into that env. Points at `.local/bin`
# (where the claude binary lives); the inherited `${PATH}` carries the node
# stack's `/usr/local` install as the floor (declared in harness.yaml),
# so `node` resolves for build-time `claude mcp add ...` (inject points,
# post_init) and the agent's Bash tool.
#
# Stays in the root_after_stacks scope (not the late clawker block) because any
# `claude` invocation in `after_claude_install` / `before_entrypoint`
# inject points reads this at session start — without `.local/bin` here, the
# user's build-time `claude mcp add ...` cannot find the `claude` binary. The
# heredoc body is structural (template-author-edited only), so locking it early
# has negligible cache cost vs the asset bumps in the late block.
RUN mkdir -p /etc/claude-code && cat > /etc/claude-code/managed-settings.json <<EOF
{
  "env": {
    "PATH": "/home/${USERNAME}/.local/bin:${PATH}"
  }
}
EOF

# Harness config-volume directories, pre-created so the volume mounts
# inherit correct ownership (paths declared by the harness bundle).
RUN mkdir -p /home/${USERNAME}/.claude && \
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/.claude 

USER ${USERNAME}
ARG ZSH_ENV=/home/${USERNAME}/.zshenv


# nvm — runtime Node version-switch tool. zsh sources .zshenv on every
# invocation, so nvm is available in interactive and non-interactive shells.
# Installed via its canonical installer (nvm-sh). Floated, not pinned: a
# frozen tag rots into an unpatched installer Dependabot can't track (curl|bash,
# not a package) — the failure mode CVE-2026-10796 caused for nvm <=0.40.4. nvm
# itself checksums the Node tarballs it downloads. Rationale: docs/threat-model.mdx.
# The root fragment's NODE_VERSION ARG is in scope here, so the installer
# auto-installs that LTS line into ~/.nvm and sets it as the default alias.
# Deliberate: shells that source nvm (zsh via .zshenv — user_run build steps
# and interactive sessions alike) resolve npm to the user-owned nvm prefix,
# making unprivileged `npm install -g` work with no system-prefix games.
# Guarded: an existing ~/.nvm (image- or user-provided) is left untouched.
RUN if [ -s "$HOME/.nvm/nvm.sh" ]; then \
      echo "clawker stack nvm: $HOME/.nvm already present — skipping install"; \
    else \
      NVM_LATEST=$(curl -sSfL https://api.github.com/repos/nvm-sh/nvm/releases/latest | jq -r '.tag_name') && \
      { [ -n "$NVM_LATEST" ] && [ "$NVM_LATEST" != "null" ]; } || { echo "ERROR: could not resolve latest nvm release tag" >&2; exit 1; } && \
      curl -sSfL "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_LATEST}/install.sh" | PROFILE=${ZSH_ENV} bash ; \
    fi

# Tell Claude Code where its config lives — must match the config volume mount.
# CP's generic seed-apply init step places the manifest seeds (statusline,
# .config.json onboarding bypass, settings.json) here on first boot.
ENV CLAUDE_CONFIG_DIR=/home/${USERNAME}/.claude
# Telemetry: pre-configured for otel-collector on clawker-net (requires 'clawker monitor up').
# 'monitor up' also provisions OpenSearch indices + Dashboards via the
# clawker-opensearch-bootstrap one-shot service before the collector starts,
# so records land in templated (not dynamically-mapped) indices.
# Disabled at container creation if monitoring stack is not running; override with agent.env
ENV CLAUDE_CODE_ENABLE_TELEMETRY=1
# Beta gate: span tracing only fires when CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
# is also set (per Claude Code docs). With both set, OTEL_TRACES_EXPORTER=otlp
# sends spans via the same OTLP base endpoint below.
ENV CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
ENV OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
ENV OTEL_METRICS_EXPORTER=otlp
ENV OTEL_LOGS_EXPORTER=otlp
ENV OTEL_TRACES_EXPORTER=otlp
# Single base endpoint; OTel SDK appends /v1/metrics, /v1/logs, /v1/traces
# per signal. Collector OTLP/HTTP receiver listens on the standard paths.
ENV OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:0
ENV OTEL_LOGS_EXPORT_INTERVAL=0
ENV OTEL_METRIC_EXPORT_INTERVAL=0

SHELL ["/bin/zsh", "-o", "pipefail", "-c"]

# Claude Code version. Build-only ARG (not ENV — CC's runtime ignores it; only
# the install RUN below consumes it). Default is resolved against the npm
# registry at template-render time, so a fresh CC release (often several a week)
# rolls this value.
#
# MUST stay here, directly above its only consumer. BuildKit invalidates the
# cache at an ARG's DECLARATION line, not at first use — that "first use, not
# definition" rule is the classic (pre-BuildKit) builder's, and Docker 23+
# builds with BuildKit by default. Hoisting this declaration up the stage would
# re-run every layer below it (stacks, git-delta, zsh-in-docker, ...) on
# every CC release. Adjacent placement scopes the CC-version cache miss to the
# install layer + the late root block alone.
# Override: clawker build --build-arg CLAUDE_CODE_VERSION=<version>
ARG CLAUDE_CODE_VERSION=2.99.99-test

# Install Claude Code
RUN curl -fsSL "https://claude.ai/install.sh" | bash -s ${CLAUDE_CODE_VERSION}

# Harness config seeds, staged for first-boot volume initialization (not
# shadowed by the config volume mount). The seed-manifest tells CP's generic
# seed-apply init step how to place each file into the harness config dir
# (paths + apply tokens match internal/consts SeedSubdir/SeedManifestFile and
# controlplane/agent ConfigSeedScript). Stays in the user-scope section so
# inject points and user Copy steps can reference the staged seeds.
COPY --chown=${USERNAME}:${USERNAME} assets/statusline.sh /home/${USERNAME}/.clawker/seed/.claude/statusline.sh
COPY --chown=${USERNAME}:${USERNAME} assets/claude-config.json /home/${USERNAME}/.clawker/seed/.claude/.config.json
COPY --chown=${USERNAME}:${USERNAME} assets/claude-settings.json /home/${USERNAME}/.clawker/seed/.claude/settings.json
RUN cat > /home/${USERNAME}/.clawker/seed-manifest <<'EOF'
copy-if-missing .claude/statusline.sh
copy-if-missing-or-empty .claude/.config.json
json-merge .claude/settings.json
EOF





# Switch back to root: clawkerd is PID 1, runs as root, owns the
# supervisor responsibilities (spawn user CMD with privilege drop,
# forward signals, reap zombies, serve the CP-dialed mTLS listener).
USER root

# --- Begin clawker-managed root assets (consolidated for build-cache locality) ---
# Every COPY/RUN in this block changes with clawker release cadence
# (embedded scripts, the managed agent prompt, firewall CA, clawkerd
# binary) and writes to root-owned paths (/usr/local/bin,
# /usr/local/share, harness-managed /etc dirs).
# Keeping them at end-of-stage means a clawker bump invalidates ONLY this
# block — the harness install blocks and config seeds stay cached above,
# and the shared base image's ID never changes. The seeds live in the
# user-scope section (before USER root) so the user_commands inject
# point can reference ~/.clawker/seed/ contents.



# Managed agent context — clawker's harness-agnostic environment briefing,
# baked at build time to the location the harness manifest declares
# (harness.yaml managed_prompt). The content is clawker-owned; the harness
# only names where its agent reads managed context from.
COPY --chown=root:root --chmod=0644 clawker-agent-prompt.md /etc/claude-code/CLAUDE.md

# Firewall CA cert for TLS inspection. docker build itself runs via host
# network (not through the per-container eBPF firewall), so curl/wget
# steps ABOVE this point don't need the CA — only runtime traffic does.
COPY clawker-ca.crt /usr/local/share/ca-certificates/clawker-firewall-ca.crt
RUN update-ca-certificates
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV CURL_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# Host-proxy and socket-forwarder binaries. Single chmod batches the four files into one layer.
COPY host-open.sh /usr/local/bin/host-open
COPY git-credential-clawker.sh /usr/local/bin/git-credential-clawker
COPY --from=callback-forwarder-builder /build/callback-forwarder /usr/local/bin/callback-forwarder
COPY --from=socket-server-builder /build/clawker-socket-server /usr/local/bin/clawker-socket-server
RUN chmod +x /usr/local/bin/host-open \
             /usr/local/bin/git-credential-clawker \
             /usr/local/bin/callback-forwarder \
             /usr/local/bin/clawker-socket-server

# clawkerd: per-container agent daemon AND PID 1 init. Reads bootstrap
# material, completes the CP-driven Register handshake, serves the
# mTLS Session listener for command dispatch, and supervises the user
# CMD across its lifetime. See cmd/clawkerd for the source + CLAUDE.md.
# Last in the block — every clawker release rolls the binary content,
# so it ends up in its own layer with the smallest possible tail.
COPY --chown=root:root --chmod=755 clawkerd /usr/local/bin/clawkerd
# --- End clawker-managed assets ---

ENTRYPOINT ["/usr/local/bin/clawkerd"]
CMD ["claude"]
