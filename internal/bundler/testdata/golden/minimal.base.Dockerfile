# Generated by Clawker - per-project shared base image on debian:bookworm-slim@sha256:60eac759739651111db372c07be67863818726f754804b8707c90979bda511df
#
# Harness-agnostic half of the image split: system packages, user setup,
# project instructions (root_run/user_run/copy), and shell tooling. Harness
# images build FROM this image (see Dockerfile.harness-image.tmpl) — keep
# the shared sections of the two templates in sync when editing.

FROM debian:bookworm-slim@sha256:60eac759739651111db372c07be67863818726f754804b8707c90979bda511df

ARG TZ=UTC
ENV TZ="$TZ"





# Install system packages. The substrate is slim, so this layer carries the
# full clawker floor: TLS trust (ca-certificates), archive tooling
# (unzip/xz-utils), download+verify tooling (curl/wget/gnupg2), and the dev
# environment clawker promises (git, zsh, sudo, gh, locales, editors).
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    less \
    procps \
    sudo \
    fzf \
    gcc \
    git \
    libc6-dev \
    zsh \
    make \
    man-db \
    unzip \
    xz-utils \
    gnupg2 \
    iproute2 \
    dnsutils \
    aggregate \
    jq \
    nano \
    vim \
    wget \
    curl \
    gh \
    locales \
    locales-all \
    && true



# Install Docker CLI (not daemon - we use host's Docker via socket mount)
RUN install -m 0755 -d /etc/apt/keyrings && \
    curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc && \
    chmod a+r /etc/apt/keyrings/docker.asc && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo \"$VERSION_CODENAME\") stable" > /etc/apt/sources.list.d/docker.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends docker-ce-cli docker-buildx-plugin docker-compose-plugin

# Setup locale
RUN locale-gen en_US.UTF-8





ARG USERNAME=claude

# Setup non-root user

RUN (groupadd --gid 1001 ${USERNAME} 2>/dev/null || groupadd ${USERNAME}) \
    && useradd --uid 1001 --gid ${USERNAME} --shell /bin/zsh --create-home ${USERNAME}

# Create docker group and add user for socket access
RUN groupadd -g 999 docker 2>/dev/null || groupadd docker 2>/dev/null || true && usermod -aG docker ${USERNAME}



# Create workspace, config, runtime, and credential directories with proper permissions.
# .gnupg and .ssh are pre-created so socket mounts don't create root-owned directories.
# .clawker-share is pre-created so the share volume mount inherits correct ownership.
# .clawker is pre-created for the same reason — the dedicated lifecycle volume
# (hook scripts, seed staging, post-init marker) copies up the image's content
# and ownership on first use, and must stay user-writable even for a harness
# that stages no seeds there.
# /run/clawker (bootstrap dir, root-owned 0700 — only clawkerd-as-root reads it) and
# /var/log/clawker (log file, root-owned — clawkerd writes the rotated log as root)
# are pre-created so clawkerd-as-PID-1 doesn't need mkdir at boot. /var/run/clawker
# is chowned to ${USERNAME} below so the user CMD (spawned by clawkerd with a
# privilege drop to ${USERNAME}) can read/write runtime state alongside the ready
# marker that clawkerd-as-root writes; the HEALTHCHECK probe itself runs as root
# (the harness image's final USER is root) and stats the ready marker
# regardless of ownership. Harness config-volume dirs are created in the
# harness image, next to the blocks that use them.
RUN mkdir -p /home/${USERNAME}/.clawker /home/${USERNAME}/.clawker-share /home/${USERNAME}/.gnupg /home/${USERNAME}/.ssh /workspace /run/clawker /var/log/clawker /var/run/clawker && \
    chmod 700 /home/${USERNAME}/.gnupg /home/${USERNAME}/.ssh && \
    chown -R ${USERNAME}:${USERNAME} /workspace /home/${USERNAME}/.clawker /home/${USERNAME}/.clawker-share /home/${USERNAME}/.gnupg /home/${USERNAME}/.ssh /var/run/clawker

# Persist bash history
RUN SNIPPET="export PROMPT_COMMAND='history -a' && export HISTFILE=/commandhistory/.bash_history" \
    && mkdir /commandhistory \
    && touch /commandhistory/.bash_history \
    && chown -R ${USERNAME} /commandhistory

WORKDIR /workspace

# Install git-delta
ARG GIT_DELTA_VERSION=0.19.1
ARG GIT_DELTA_SHA256_AMD64=3b3064c5e474d120366f5917f54c612bbfd5733a70e5d10988d8028c7c877de9
ARG GIT_DELTA_SHA256_ARM64=1bd252110eafa1065c0798f9e68de0682127408e4b53db79733efa72c53b68bf
RUN mkdir -p /tmp/downloads && \
    ARCH=$(dpkg --print-architecture) && \
    DEB="git-delta_${GIT_DELTA_VERSION}_${ARCH}.deb" && \
    [ -f "/tmp/downloads/$DEB" ] || wget -O "/tmp/downloads/$DEB" "https://github.com/dandavison/delta/releases/download/${GIT_DELTA_VERSION}/$DEB" && \
    if [ "$ARCH" = "amd64" ]; then EXPECTED_SHA="${GIT_DELTA_SHA256_AMD64}"; \
    elif [ "$ARCH" = "arm64" ]; then EXPECTED_SHA="${GIT_DELTA_SHA256_ARM64}"; \
    else echo "ERROR: git-delta does not support architecture: $ARCH (only amd64 and arm64)" >&2; exit 1; fi && \
    echo "$EXPECTED_SHA  /tmp/downloads/$DEB" | sha256sum -c - && \
    dpkg -i "/tmp/downloads/$DEB"

# Switch to non-root user for ENV/WORKDIR resolution. clawkerd (PID 1)
# is invoked as root by Docker — the USER directive only affects
# ENV/WORKDIR/RUN scope below this line. The harness image switches back
# to root for its clawker-managed assets and leaves the final image at
# USER root for clawkerd-as-PID-1.
USER ${USERNAME}
ENV CLAWKER_USER=${USERNAME}

# Set static environment (PATH, SHELL, BROWSER — not config-dependent).
# `.local/bin` is load-bearing: harness installers drop their CLI binaries
# there, so without this PATH entry the agent itself is not invokable.
# Side benefit: any user_run installer that follows XDG (uv, pip --user,
# cargo, etc.) lands on PATH automatically.
ENV HOME=/home/${USERNAME}
ENV PATH=${HOME}/.local/bin:$PATH


# Set BROWSER so CLI tools (like Claude Code) use host-open for URLs
ENV BROWSER=/usr/local/bin/host-open
# Terminal color defaults; RuntimeEnv may override these based on host capabilities,
# using safe fallback values (xterm-256color, truecolor) rather than passing through host TERM.
ENV TERM=xterm-256color
ENV COLORTERM=truecolor
ENV LANG=en_US.UTF-8

# zsh env file pre-created so any harness or user step can append to it;
# zsh sources .zshenv on every invocation (interactive and non-interactive).
SHELL ["/bin/zsh", "-o", "pipefail", "-c"]
ARG ZSH_ENV=/home/${USERNAME}/.zshenv
RUN touch ${ZSH_ENV}

ENV SHELL=/bin/zsh




# Use zsh-in-docker to configure plugins and theme
ARG ZSH_IN_DOCKER_VERSION=1.2.1
ARG ZSH_IN_DOCKER_SHA256=0cf15b6f9c63a8103eb33bad87dc4b43fed0e0ad5884dff90f943ee1e868796e
ARG ZSH_THEME=default
RUN wget -O /tmp/zsh-in-docker.sh "https://github.com/deluan/zsh-in-docker/releases/download/v${ZSH_IN_DOCKER_VERSION}/zsh-in-docker.sh" && \
    echo "${ZSH_IN_DOCKER_SHA256}  /tmp/zsh-in-docker.sh" | sha256sum -c - && \
    sh /tmp/zsh-in-docker.sh \
    -t ${ZSH_THEME} \
    -p git \
    -p fzf \
    -a "source /usr/share/doc/fzf/examples/key-bindings.zsh" \
    -a "source /usr/share/doc/fzf/examples/completion.zsh" \
    -a "export PROMPT_COMMAND='history -a' && export HISTFILE=/commandhistory/.bash_history" \
    -a "export TERM=xterm-256color" \
    -x && \
    rm /tmp/zsh-in-docker.sh





# Health check for container readiness (checks for ready signal file).
# Inherited by harness images; the probe runs as root there (final USER).
HEALTHCHECK --interval=5s --timeout=3s --start-period=30s --retries=3 \
    CMD test -f /var/run/clawker/ready || exit 1
