{{/*
  Claude Code harness — fills the master Dockerfile.tmpl block slots.
  Each define's body is emitted verbatim at the block's position in the
  master; the master owns ordering and cache architecture.
*/}}

{{define "block_1" -}}
# Node.js (≥22.10) trusts the OS CA bundle. Set globally — applies to root
# (build-time RUN steps) AND to the unprivileged ${USERNAME} (Claude Code
# hooks, user `npm`/`npx`). When the firewall MITM CA is added to
# /etc/ssl/certs via update-ca-certificates (clawker's late root block),
# `fetch()` and TLS calls from any process transparently trust clawker's
# interception cert.
ENV NODE_USE_SYSTEM_CA=1

# Root-global Node.js on /usr/local — the baked default for Claude Code's
# hooks/MCP tooling, any root_run / system build step, and the agent's Bash
# tool (all resolve it from ${PATH}). nvm (installed in the post-user_run
# block) is the runtime version-switch tool layered on top; this is the
# stable base.
#
# NODE_VERSION names the LTS *line* (e.g. "24"), not an exact patch; the latest
# patch in that line is resolved per-build from nodejs.org/dist/index.json so
# rebuilds float forward onto security patches (dep-rot rationale: see the nvm
# block below + docs/threat-model.mdx). Integrity is verified on every path:
#   - Debian: prebuilt tarball from nodejs.org/dist, GPG-verified via SHASUMS256.txt.asc.
#   - Alpine x86_64: musl prebuilt from unofficial-builds.nodejs.org, sha256-verified
#     against that mirror's SHASUMS256.txt (unofficial builds are unsigned — upstream's
#     musl integrity level).
#   - Alpine other arches: source build (./configure + make), GPG-verified against
#     nodejs.org/dist SHASUMS256.txt.
# All paths land node/npm under /usr/local.
ARG NODE_VERSION=24
{{if .IsAlpine -}}
{{- if $.BuildKitEnabled}}
RUN --mount=type=cache,target=/var/cache/apk,sharing=locked \
    apk add --no-cache libstdc++ && \
    apk add --no-cache --virtual .build-deps curl && \
{{- else}}
RUN apk add --no-cache libstdc++ && \
    apk add --no-cache --virtual .build-deps curl && \
{{- end}}
    NODE_LTS_VERSION=$(curl -sSfL https://nodejs.org/dist/index.json | jq -r --arg ver "$NODE_VERSION" '[.[] | select(.lts != false)] | map(select(.version | startswith("v" + $ver + "."))) | .[0].version' | sed 's/^v//') && \
    { [ -n "$NODE_LTS_VERSION" ] && [ "$NODE_LTS_VERSION" != "null" ]; } || { echo "ERROR: could not resolve Node LTS line ${NODE_VERSION}" >&2; exit 1; } && \
    ARCH= OPENSSL_ARCH='linux*' && alpineArch="$(apk --print-arch)" && \
    case "${alpineArch##*-}" in \
      x86_64) ARCH='x64' OPENSSL_ARCH=linux-x86_64 ;; \
      x86) OPENSSL_ARCH=linux-elf ;; \
      aarch64) OPENSSL_ARCH=linux-aarch64 ;; \
      arm*) OPENSSL_ARCH=linux-armv4 ;; \
      ppc64le) OPENSSL_ARCH=linux-ppc64le ;; \
      s390x) OPENSSL_ARCH=linux-s390x ;; \
      *) ;; \
    esac && \
    if [ "$ARCH" = "x64" ]; then \
      set -eu; \
      curl -fsSLO --compressed "https://unofficial-builds.nodejs.org/download/release/v$NODE_LTS_VERSION/node-v$NODE_LTS_VERSION-linux-$ARCH-musl.tar.xz" && \
      curl -fsSLO --compressed "https://unofficial-builds.nodejs.org/download/release/v$NODE_LTS_VERSION/SHASUMS256.txt" && \
      grep " node-v$NODE_LTS_VERSION-linux-$ARCH-musl.tar.xz\$" SHASUMS256.txt | sha256sum -c - && \
      tar -xJf "node-v$NODE_LTS_VERSION-linux-$ARCH-musl.tar.xz" -C /usr/local --strip-components=1 --no-same-owner && \
      ln -s /usr/local/bin/node /usr/local/bin/nodejs && \
      rm -f SHASUMS256.txt; \
    else \
      echo "Building from source" && \
      apk add --no-cache --virtual .build-deps-full \
          binutils-gold \
          g++ \
          gcc \
          gnupg \
          libgcc \
          linux-headers \
          make \
          python3 \
          py-setuptools && \
      export GNUPGHOME="$(mktemp -d)" && \
      for key in \
        5BE8A3F6C8A5C01D106C0AD820B1A390B168D356 \
        DD792F5973C6DE52C432CBDAC77ABFA00DDBF2B7 \
        CC68F5A3106FF448322E48ED27F5E38D5B0A215F \
        8FCCA13FEF1D0C2E91008E09770F7A9A5AE15600 \
        890C08DB8579162FEE0DF9DB8BEAB4DFCF555EF4 \
        C82FA3AE1CBEDC6BE46B9360C43CEC45C17AB93C \
        108F52B48DB57BB0CC439B2997B01419BD92F80A \
        A363A499291CBBC940DD62E41F10027AF002F8B0 \
      ; do \
        { gpg --batch --keyserver hkps://keys.openpgp.org --recv-keys "$key" && gpg --batch --fingerprint "$key"; } || \
        { gpg --batch --keyserver keyserver.ubuntu.com --recv-keys "$key" && gpg --batch --fingerprint "$key"; } ; \
      done && \
      curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/node-v$NODE_LTS_VERSION.tar.xz" && \
      curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/SHASUMS256.txt.asc" && \
      gpg --batch --decrypt --output SHASUMS256.txt SHASUMS256.txt.asc && \
      gpgconf --kill all && \
      rm -rf "$GNUPGHOME" && \
      grep " node-v$NODE_LTS_VERSION.tar.xz\$" SHASUMS256.txt | sha256sum -c - && \
      tar -xf "node-v$NODE_LTS_VERSION.tar.xz" && \
      cd "node-v$NODE_LTS_VERSION" && \
      ./configure && \
      make -j$(getconf _NPROCESSORS_ONLN) V= && \
      make install && \
      apk del .build-deps-full && \
      cd .. && \
      rm -Rf "node-v$NODE_LTS_VERSION" && \
      rm "node-v$NODE_LTS_VERSION.tar.xz" SHASUMS256.txt.asc SHASUMS256.txt; \
    fi && \
    rm -f "node-v$NODE_LTS_VERSION-linux-$ARCH-musl.tar.xz" && \
    find /usr/local/include/node/openssl/archs -mindepth 1 -maxdepth 1 ! -name "$OPENSSL_ARCH" -exec rm -rf {} \; && \
    apk del .build-deps && \
    node --version && \
    npm --version && \
    rm -rf /tmp/*
{{else -}}
{{- if $.BuildKitEnabled}}
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates dirmngr xz-utils libatomic1 && \
{{- else}}
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates dirmngr xz-utils libatomic1 && \
{{- end}}
    NODE_LTS_VERSION=$(curl -sSfL https://nodejs.org/dist/index.json | jq -r --arg ver "$NODE_VERSION" '[.[] | select(.lts != false)] | map(select(.version | startswith("v" + $ver + "."))) | .[0].version' | sed 's/^v//') && \
    { [ -n "$NODE_LTS_VERSION" ] && [ "$NODE_LTS_VERSION" != "null" ]; } || { echo "ERROR: could not resolve Node LTS line ${NODE_VERSION}" >&2; exit 1; } && \
    ARCH= && dpkgArch="$(dpkg --print-architecture)" && \
    case "${dpkgArch##*-}" in \
      amd64) ARCH='x64' ;; \
      arm64) ARCH='arm64' ;; \
      *) echo "ERROR: node prebuilt does not support architecture: $dpkgArch (only amd64 and arm64)" >&2; exit 1 ;; \
    esac && \
    set -ex && \
    export GNUPGHOME="$(mktemp -d)" && \
    for key in \
      5BE8A3F6C8A5C01D106C0AD820B1A390B168D356 \
      DD792F5973C6DE52C432CBDAC77ABFA00DDBF2B7 \
      CC68F5A3106FF448322E48ED27F5E38D5B0A215F \
      8FCCA13FEF1D0C2E91008E09770F7A9A5AE15600 \
      890C08DB8579162FEE0DF9DB8BEAB4DFCF555EF4 \
      C82FA3AE1CBEDC6BE46B9360C43CEC45C17AB93C \
      108F52B48DB57BB0CC439B2997B01419BD92F80A \
      A363A499291CBBC940DD62E41F10027AF002F8B0 \
    ; do \
      { gpg --batch --keyserver hkps://keys.openpgp.org --recv-keys "$key" && gpg --batch --fingerprint "$key"; } || \
      { gpg --batch --keyserver keyserver.ubuntu.com --recv-keys "$key" && gpg --batch --fingerprint "$key"; } ; \
    done && \
    curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" && \
    curl -fsSLO --compressed "https://nodejs.org/dist/v$NODE_LTS_VERSION/SHASUMS256.txt.asc" && \
    gpg --batch --decrypt --output SHASUMS256.txt SHASUMS256.txt.asc && \
    gpgconf --kill all && \
    rm -rf "$GNUPGHOME" && \
    grep " node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz\$" SHASUMS256.txt | sha256sum -c - && \
    tar -xJf "node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" -C /usr/local --strip-components=1 --no-same-owner && \
    rm "node-v$NODE_LTS_VERSION-linux-$ARCH.tar.xz" SHASUMS256.txt.asc SHASUMS256.txt && \
    ln -s /usr/local/bin/node /usr/local/bin/nodejs && \
    node --version && npm --version
{{end}}
{{- end}}

{{define "block_2" -}}
# Managed enterprise settings (Linux managed path, highest precedence,
# cannot be overridden by user/project settings). REQUIRED — do not
# remove. Claude Code's Bash tool runs `/bin/zsh -c` and sources its own
# shell snapshot AFTER zsh init files, so the snapshot's PATH overrides
# anything `.zshenv` exports; managed-settings.json is the only documented
# enterprise mechanism that injects into that env. Points at `.local/bin`
# (where the claude binary lives); the inherited `${PATH}` carries the root
# `/usr/local` Node install as the floor, so `node` resolves for build-time
# `claude mcp add ...` (inject points, post_init) and the agent's Bash tool.
#
# Stays in early root scope (not the late clawker block) because any
# `claude` invocation in `after_claude_install` / `before_entrypoint`
# inject points reads this at session start — without `.local/bin` here, the
# user's build-time `claude mcp add ...` cannot find the `claude` binary. The
# heredoc body is structural (template-author-edited only), so locking it early
# has negligible cache cost vs the asset bumps in the late block.
RUN mkdir -p /etc/claude-code && cat > /etc/claude-code/managed-settings.json <<EOF
{
  "env": {
    "PATH": "/home/${USERNAME}/.local/bin:${PATH}"
  }
}
EOF
{{- end}}

{{define "block_3" -}}
# Tell Claude Code where its config lives — must match the config volume mount.
# CP's generic seed-apply init step places the manifest seeds (statusline,
# .config.json onboarding bypass, settings.json) here on first boot.
ENV CLAUDE_CONFIG_DIR=/home/${USERNAME}/.claude
# Telemetry: pre-configured for otel-collector on clawker-net (requires 'clawker monitor up').
# 'monitor up' also provisions OpenSearch indices + Dashboards via the
# clawker-opensearch-bootstrap one-shot service before the collector starts,
# so records land in templated (not dynamically-mapped) indices.
# Disabled at container creation if monitoring stack is not running; override with agent.env
ENV CLAUDE_CODE_ENABLE_TELEMETRY=1
# Beta gate: span tracing only fires when CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
# is also set (per Claude Code docs). With both set, OTEL_TRACES_EXPORTER=otlp
# sends spans via the same OTLP base endpoint below.
ENV CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
ENV OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
ENV OTEL_METRICS_EXPORTER=otlp
ENV OTEL_LOGS_EXPORTER=otlp
ENV OTEL_TRACES_EXPORTER=otlp
# Single base endpoint; OTel SDK appends /v1/metrics, /v1/logs, /v1/traces
# per signal. Collector OTLP/HTTP receiver listens on the standard paths.
ENV OTEL_EXPORTER_OTLP_ENDPOINT={{.OtelEndpoint}}
{{- if .OtelIncludeAccountUUID}}
ENV OTEL_METRICS_INCLUDE_ACCOUNT_UUID=true
{{- end}}
{{- if .OtelIncludeSessionID}}
ENV OTEL_METRICS_INCLUDE_SESSION_ID=true
{{- end}}
ENV OTEL_LOGS_EXPORT_INTERVAL={{.OtelLogsExportInterval}}
ENV OTEL_METRIC_EXPORT_INTERVAL={{.OtelMetricExportInterval}}
{{- if .OtelLogToolDetails}}
ENV OTEL_LOG_TOOL_DETAILS=1
{{- end}}
{{- if .OtelLogUserPrompts}}
ENV OTEL_LOG_USER_PROMPTS=1
{{- end}}
{{- end}}

{{define "block_4" -}}
# nvm — runtime Node version-switch tool (the baked default node lives on
# /usr/local from the root install in block_1). zsh sources .zshenv on every
# invocation, so nvm is available in interactive and non-interactive shells.
# Install nvm via its canonical installer (nvm-sh). Floated, not pinned: a
# frozen tag rots into an unpatched installer Dependabot can't track (curl|bash,
# not a package) — the failure mode CVE-2026-10796 caused for nvm <=0.40.4. nvm
# itself checksums the Node tarballs it downloads. Rationale: docs/threat-model.mdx.
RUN NVM_LATEST=$(curl -sSfL https://api.github.com/repos/nvm-sh/nvm/releases/latest | jq -r '.tag_name') && \
      { [ -n "$NVM_LATEST" ] && [ "$NVM_LATEST" != "null" ]; } || { echo "ERROR: could not resolve latest nvm release tag" >&2; exit 1; } && \
      curl -sSfL https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_LATEST}/install.sh | PROFILE=${ZSH_ENV} bash

# Claude Code version. Build-only ARG (not ENV — CC's runtime ignores it; only
# the install RUN below consumes it). Default is resolved against the npm
# registry at template-render time, so a fresh CC release (often several a week)
# rolls this value.
#
# MUST stay here, directly above its only consumer. BuildKit invalidates the
# cache at an ARG's DECLARATION line, not at first use — that "first use, not
# definition" rule is the classic (pre-BuildKit) builder's, and Docker 23+
# builds with BuildKit by default. Hoisting this declaration up the stage would
# re-run every layer below it (apt/apk, Node, git-delta, zsh-in-docker, ...) on
# every CC release. Adjacent placement scopes the CC-version cache miss to the
# install layer + the late root block alone.
# Override: clawker build --build-arg CLAUDE_CODE_VERSION=<version>
ARG CLAUDE_CODE_VERSION={{.HarnessVersion}}

# Install Claude Code
{{- if .BuildKitEnabled}}
RUN --mount=type=cache,target=/home/${USERNAME}/.npm \
    curl -fsSL "https://claude.ai/install.sh" | bash -s ${CLAUDE_CODE_VERSION}
{{- else}}
RUN curl -fsSL "https://claude.ai/install.sh" | bash -s ${CLAUDE_CODE_VERSION}
{{- end}}
{{- end}}

{{define "block_5" -}}
# /etc/claude-code is created by the managed-settings.json RUN above; COPY auto-creates intermediates either way.
COPY assets/clawker-agent-prompt.md /etc/claude-code/CLAUDE.md
{{- end}}

{{define "block_6" -}}
CMD ["claude"]
{{- end}}
