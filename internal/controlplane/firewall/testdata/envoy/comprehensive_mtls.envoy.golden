                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: http
                                    network.protocol.version: '%PROTOCOL%'
                                    network.transport: quic
                                    path: '%REQ(:PATH)%'
                                    req_duration_ms: '%REQUEST_DURATION%'
                                    resp_duration_ms: '%RESPONSE_DURATION%'
                                    resp_tx_duration_ms: '%RESPONSE_TX_DURATION%'
                                    response_code: '%RESPONSE_CODE%'
                                    response_code_details: '%RESPONSE_CODE_DETAILS%'
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: '%REQUESTED_SERVER_NAME%'
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "true"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                                    upstream_transport_failure_reason: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    user_agent: '%REQ(USER-AGENT)%'
                        - name: envoy.access_loggers.open_telemetry
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.open_telemetry.v3.OpenTelemetryAccessLogConfig
                            attributes:
                                values:
                                    - key: action
                                      value:
                                        string_value: '%METADATA(ROUTE:clawker:action)%'
                                    - key: bytes_received
                                      value:
                                        string_value: '%BYTES_RECEIVED%'
                                    - key: bytes_sent
                                      value:
                                        string_value: '%BYTES_SENT%'
                                    - key: client.address
                                      value:
                                        string_value: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    - key: duration_ms
                                      value:
                                        string_value: '%DURATION%'
                                    - key: listener_ip
                                      value:
                                        string_value: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    - key: method
                                      value:
                                        string_value: '%REQ(:METHOD)%'
                                    - key: network.peer.address
                                      value:
                                        string_value: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    - key: network.peer.port
                                      value:
                                        string_value: '%UPSTREAM_REMOTE_PORT%'
                                    - key: network.protocol.name
                                      value:
                                        string_value: http
                                    - key: network.protocol.version
                                      value:
                                        string_value: '%PROTOCOL%'
                                    - key: network.transport
                                      value:
                                        string_value: quic
                                    - key: path
                                      value:
                                        string_value: '%REQ(:PATH)%'
                                    - key: req_duration_ms
                                      value:
                                        string_value: '%REQUEST_DURATION%'
                                    - key: resp_duration_ms
                                      value:
                                        string_value: '%RESPONSE_DURATION%'
                                    - key: resp_tx_duration_ms
                                      value:
                                        string_value: '%RESPONSE_TX_DURATION%'
                                    - key: response_code
                                      value:
                                        string_value: '%RESPONSE_CODE%'
                                    - key: response_code_details
                                      value:
                                        string_value: '%RESPONSE_CODE_DETAILS%'
                                    - key: response_flags
                                      value:
                                        string_value: '%RESPONSE_FLAGS%'
                                    - key: server.address
                                      value:
                                        string_value: '%REQUESTED_SERVER_NAME%'
                                    - key: tls.cipher
                                      value:
                                        string_value: '%DOWNSTREAM_TLS_CIPHER%'
                                    - key: tls.established
                                      value:
                                        string_value: "true"
                                    - key: tls.protocol.version
                                      value:
                                        string_value: '%DOWNSTREAM_TLS_VERSION%'
                                    - key: upstream_bytes_received
                                      value:
                                        string_value: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    - key: upstream_bytes_sent
                                      value:
                                        string_value: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    - key: upstream_tls_cipher
                                      value:
                                        string_value: '%UPSTREAM_TLS_CIPHER%'
                                    - key: upstream_tls_version
                                      value:
                                        string_value: '%UPSTREAM_TLS_VERSION%'
