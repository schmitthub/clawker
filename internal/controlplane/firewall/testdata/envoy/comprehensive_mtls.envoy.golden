admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - connect_timeout: 1s
          load_assignment:
            cluster_name: deny_cluster
            endpoints: []
          name: deny_cluster
          type: STATIC
        - connect_timeout: 10s
          load_assignment:
            cluster_name: http_192_168_1_1_80
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: 192.168.1.1
                                port_value: 80
          name: http_192_168_1_1_80
          type: STATIC
        - connect_timeout: 10s
          load_assignment:
            cluster_name: http_192_168_1_1_8080
            endpoints:
