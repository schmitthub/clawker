                    http_filters:
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    http2_protocol_options:
                        allow_connect: true
                        max_concurrent_streams: 100
                    http3_protocol_options:
                        allow_extended_connect: true
                    merge_slashes: true
                    normalize_path: true
                    path_with_escaped_slashes_action: UNESCAPE_AND_REDIRECT
                    route_config:
                        name: http_egress_routes
                        virtual_hosts:
                            - domains:
                                - secure.example.com
                                - secure.example.com:443
                              name: secure_example_com_443
                              routes:
                                - match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: allowed
                                  route:
                                    cluster: tls_secure_example_com_443
                                    timeout: 0s
                                    upgrade_configs:
                                        - upgrade_type: websocket
                            - domains:
                                - '*'
                              name: deny_all
                              routes:
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Forbidden
                                    status: 403
                                  match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: denied
                    stat_prefix: http_egress
