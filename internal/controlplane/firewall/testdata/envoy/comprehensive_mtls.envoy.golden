                                      value:
                                        string_value: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    - key: user_agent
                                      value:
                                        string_value: '%REQ(USER-AGENT)%'
                            body:
                                string_value: envoy access_log
                            grpc_service:
                                envoy_grpc:
                                    cluster_name: otel_collector_als
                            resource_attributes:
                                values:
                                    - key: service.name
                                      value:
                                        string_value: envoy
                    codec_type: HTTP3
