                            socket_address:
                                address: realtime.io
                                port_value: 80
          name: http_realtime_io_80
          type: LOGICAL_DNS
        - cluster_type:
            name: envoy.clusters.dynamic_forward_proxy
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.clusters.dynamic_forward_proxy.v3.ClusterConfig
                dns_cache_config:
                    dns_lookup_family: V4_ONLY
                    name: https_dfp_cache
          connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: https_dfp
          transport_socket:
            name: envoy.transport_sockets.tls
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
                common_tls_context:
                    alpn_protocols:
                        - h2
                        - http/1.1
                    tls_params:
                        ecdh_curves:
                            - X25519
                            - P-256
                            - P-384
                    validation_context:
                        trusted_ca:
                            filename: /etc/ssl/certs/ca-certificates.crt
          typed_extension_protocol_options:
            envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
                '@type': type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
                auto_config:
                    http_protocol_options: {}
                    http2_protocol_options: {}
                upstream_http_protocol_options:
                    auto_san_validation: true
                    auto_sni: true
        - connect_timeout: 1s
          load_assignment:
            cluster_name: otel_collector_als
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: otel-collector
                                port_value: 4319
          name: otel_collector_als
          transport_socket:
            name: envoy.transport_sockets.tls
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
                common_tls_context:
                    tls_certificates:
                        - certificate_chain:
                            filename: /etc/envoy/otel-tls/client.pem
                          private_key:
                            filename: /etc/envoy/otel-tls/client.key
                    validation_context:
                        match_typed_subject_alt_names:
                            - matcher:
                                exact: otel-collector
                              san_type: DNS
                        trusted_ca:
                            filename: /etc/envoy/otel-tls/ca.pem
                sni: otel-collector
          type: STRICT_DNS
          typed_extension_protocol_options:
            envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
                '@type': type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
                explicit_http_config:
                    http2_protocol_options: {}
