                    - endpoint:
                        address:
                            socket_address:
                                address: 192.168.1.2
                                port_value: 80
          name: http_192_168_1_2_80
          type: STATIC
        - connect_timeout: 10s
          dns_lookup_family: V4_ONLY
          load_assignment:
            cluster_name: http_api_site_com_80
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: api.site.com
                                port_value: 80
          name: http_api_site_com_80
          type: LOGICAL_DNS
        - cluster_type:
            name: envoy.clusters.dynamic_forward_proxy
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.clusters.dynamic_forward_proxy.v3.ClusterConfig
                dns_cache_config:
                    dns_lookup_family: V4_ONLY
                    name: http_dfp_cache
          connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: http_dfp
        - connect_timeout: 10s
          dns_lookup_family: V4_ONLY
          load_assignment:
            cluster_name: http_example_com_80
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: example.com
                                port_value: 80
          name: http_example_com_80
          type: LOGICAL_DNS
        - connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: http_origdst_10_0_0_0_24_8080
          type: ORIGINAL_DST
        - connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: http_origdst_10_20_0_0_24_80
          type: ORIGINAL_DST
        - connect_timeout: 10s
