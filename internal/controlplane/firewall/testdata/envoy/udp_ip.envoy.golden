admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - connect_timeout: 10s
          load_assignment:
            cluster_name: udp_192_168_1_9_3478
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: 192.168.1.9
                                port_value: 3478
          name: udp_192_168_1_9_3478
          type: STATIC
    listeners:
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 16000
                protocol: UDP
          listener_filters:
            - name: envoy.filters.udp_listener.udp_proxy
              typed_config:
                '@type': type.googleapis.com/envoy.extensions.filters.udp.udp_proxy.v3.UdpProxyConfig
                access_log:
                    - name: envoy.access_loggers.stdout
                      typed_config:
                        '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                        log_format:
                            json_format:
                                action: allowed
                                bytes_received: '%BYTES_RECEIVED%'
                                bytes_sent: '%BYTES_SENT%'
                                client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                duration_ms: '%DURATION%'
                                listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                network.protocol.name: udp
                                network.transport: udp
                                response_flags: '%RESPONSE_FLAGS%'
                                server.address: 192.168.1.9
                                tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                tls.established: "false"
                                tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                matcher:
                    on_no_match:
                        action:
                            name: route
                            typed_config:
                                '@type': type.googleapis.com/envoy.extensions.filters.udp.udp_proxy.v3.Route
                                cluster: udp_192_168_1_9_3478
                stat_prefix: udp_192_168_1_9_3478
          name: udp_192_168_1_9_3478
