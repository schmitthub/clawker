admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - connect_timeout: 1s
          load_assignment:
            cluster_name: deny_cluster
            endpoints: []
          name: deny_cluster
          type: STATIC
        - connect_timeout: 10s
          load_assignment:
            cluster_name: tcp_192_168_1_5_5432
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: 192.168.1.5
                                port_value: 5432
          name: tcp_192_168_1_5_5432
          type: STATIC
        - connect_timeout: 10s
          load_assignment:
            cluster_name: tcp_203_0_113_7_22
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: 203.0.113.7
                                port_value: 22
          name: tcp_203_0_113_7_22
          type: STATIC
        - connect_timeout: 10s
          lb_policy: CLUSTER_PROVIDED
          name: tcp_origdst_10_0_0_0_24_5432
          type: ORIGINAL_DST
    listeners:
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 10000
          default_filter_chain:
            filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    cluster: deny_cluster
                    stat_prefix: egress_deny
          filter_chains:
            - filter_chain_match:
                destination_port: 5432
                prefix_ranges:
                    - address_prefix: 192.168.1.5
                      prefix_len: 32
                transport_protocol: raw_buffer
              filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: allowed
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: tcp
                                    network.transport: tcp
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: 192.168.1.5
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "false"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                    cluster: tcp_192_168_1_5_5432
                    stat_prefix: tcp_192_168_1_5_5432
            - filter_chain_match:
                destination_port: 5432
                prefix_ranges:
                    - address_prefix: 10.0.0.0
                      prefix_len: 24
                transport_protocol: raw_buffer
              filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: allowed
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: tcp
                                    network.transport: tcp
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: 10.0.0.0/24
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "false"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                    cluster: tcp_origdst_10_0_0_0_24_5432
                    stat_prefix: tcp_origdst_10_0_0_0_24_5432
            - filter_chain_match:
                destination_port: 22
                prefix_ranges:
                    - address_prefix: 203.0.113.7
                      prefix_len: 32
                transport_protocol: raw_buffer
              filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: allowed
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: ssh
                                    network.transport: tcp
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: 203.0.113.7
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "false"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                    cluster: tcp_203_0_113_7_22
                    stat_prefix: tcp_203_0_113_7_22
          name: egress
          use_original_dst: true
