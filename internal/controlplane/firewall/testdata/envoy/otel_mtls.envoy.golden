admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - connect_timeout: 1s
          load_assignment:
            cluster_name: deny_cluster
            endpoints: []
          name: deny_cluster
          type: STATIC
        - connect_timeout: 10s
          dns_lookup_family: V4_ONLY
          load_assignment:
            cluster_name: http_example_com_80
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: example.com
                                port_value: 80
          name: http_example_com_80
          type: LOGICAL_DNS
    listeners:
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 10000
          default_filter_chain:
            filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    cluster: deny_cluster
                    stat_prefix: egress_deny
          filter_chains:
            - filter_chain_match:
                transport_protocol: raw_buffer
              filters:
                - name: envoy.filters.network.http_connection_manager
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: '%METADATA(ROUTE:clawker:action)%'
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    method: '%REQ(:METHOD)%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: http
                                    network.protocol.version: '%PROTOCOL%'
                                    network.transport: tcp
                                    path: '%REQ(:PATH)%'
                                    req_duration_ms: '%REQUEST_DURATION%'
                                    resp_duration_ms: '%RESPONSE_DURATION%'
                                    resp_tx_duration_ms: '%RESPONSE_TX_DURATION%'
                                    response_code: '%RESPONSE_CODE%'
                                    response_code_details: '%RESPONSE_CODE_DETAILS%'
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: '%REQ(Host)%'
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "false"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                                    upstream_transport_failure_reason: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    user_agent: '%REQ(USER-AGENT)%'
                        - name: envoy.access_loggers.open_telemetry
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.open_telemetry.v3.OpenTelemetryAccessLogConfig
                            attributes:
                                values:
                                    - key: action
                                      value:
                                        string_value: '%METADATA(ROUTE:clawker:action)%'
                                    - key: bytes_received
                                      value:
                                        string_value: '%BYTES_RECEIVED%'
                                    - key: bytes_sent
                                      value:
                                        string_value: '%BYTES_SENT%'
                                    - key: client.address
                                      value:
                                        string_value: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    - key: duration_ms
                                      value:
                                        string_value: '%DURATION%'
                                    - key: listener_ip
                                      value:
                                        string_value: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    - key: method
                                      value:
                                        string_value: '%REQ(:METHOD)%'
                                    - key: network.peer.address
                                      value:
                                        string_value: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    - key: network.peer.port
                                      value:
                                        string_value: '%UPSTREAM_REMOTE_PORT%'
                                    - key: network.protocol.name
                                      value:
                                        string_value: http
                                    - key: network.protocol.version
                                      value:
                                        string_value: '%PROTOCOL%'
                                    - key: network.transport
                                      value:
                                        string_value: tcp
                                    - key: path
                                      value:
                                        string_value: '%REQ(:PATH)%'
                                    - key: req_duration_ms
                                      value:
                                        string_value: '%REQUEST_DURATION%'
                                    - key: resp_duration_ms
                                      value:
                                        string_value: '%RESPONSE_DURATION%'
                                    - key: resp_tx_duration_ms
                                      value:
                                        string_value: '%RESPONSE_TX_DURATION%'
                                    - key: response_code
                                      value:
                                        string_value: '%RESPONSE_CODE%'
                                    - key: response_code_details
                                      value:
                                        string_value: '%RESPONSE_CODE_DETAILS%'
                                    - key: response_flags
                                      value:
                                        string_value: '%RESPONSE_FLAGS%'
                                    - key: server.address
                                      value:
                                        string_value: '%REQ(Host)%'
                                    - key: tls.cipher
                                      value:
                                        string_value: '%DOWNSTREAM_TLS_CIPHER%'
                                    - key: tls.established
                                      value:
                                        string_value: "false"
                                    - key: tls.protocol.version
                                      value:
                                        string_value: '%DOWNSTREAM_TLS_VERSION%'
                                    - key: upstream_bytes_received
                                      value:
                                        string_value: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    - key: upstream_bytes_sent
                                      value:
                                        string_value: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    - key: upstream_tls_cipher
                                      value:
                                        string_value: '%UPSTREAM_TLS_CIPHER%'
                                    - key: upstream_tls_version
                                      value:
                                        string_value: '%UPSTREAM_TLS_VERSION%'
                                    - key: upstream_transport_failure_reason
                                      value:
                                        string_value: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    - key: user_agent
                                      value:
                                        string_value: '%REQ(USER-AGENT)%'
                            body:
                                string_value: envoy access_log
                            grpc_service:
                                envoy_grpc:
                                    cluster_name: otel_collector_als
                            resource_attributes:
                                values:
                                    - key: service.name
                                      value:
                                        string_value: envoy
                    codec_type: AUTO
                    common_http_protocol_options:
                        headers_with_underscores_action: REJECT_REQUEST
                    http_filters:
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    http2_protocol_options:
                        max_concurrent_streams: 100
                    merge_slashes: true
                    normalize_path: true
                    path_with_escaped_slashes_action: UNESCAPE_AND_REDIRECT
                    route_config:
                        name: http_egress_routes
                        virtual_hosts:
                            - domains:
                                - example.com
                                - example.com:80
                              name: example_com_80
                              routes:
                                - match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: allowed
                                  route:
                                    cluster: http_example_com_80
                                    timeout: 0s
                            - domains:
                                - '*'
                              name: deny_all
                              routes:
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Forbidden
                                    status: 403
                                  match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: denied
                    stat_prefix: http_egress
          name: egress
