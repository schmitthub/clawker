admin:
    address:
        socket_address:
            address: 127.0.0.1
            port_value: 9901
static_resources:
    clusters:
        - connect_timeout: 1s
          load_assignment:
            cluster_name: deny_cluster
            endpoints: []
          name: deny_cluster
          type: STATIC
        - connect_timeout: 10s
          dns_lookup_family: V4_ONLY
          load_assignment:
            cluster_name: tls_stream_anthropic_com_443
            endpoints:
                - lb_endpoints:
                    - endpoint:
                        address:
                            socket_address:
                                address: stream.anthropic.com
                                port_value: 443
          name: tls_stream_anthropic_com_443
          transport_socket:
            name: envoy.transport_sockets.tls
            typed_config:
                '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
                common_tls_context:
                    alpn_protocols:
                        - http/1.1
                    tls_params:
                        ecdh_curves:
                            - X25519
                            - P-256
                            - P-384
                    validation_context:
                        trusted_ca:
                            filename: /etc/ssl/certs/ca-certificates.crt
          type: LOGICAL_DNS
          typed_extension_protocol_options:
            envoy.extensions.upstreams.http.v3.HttpProtocolOptions:
                '@type': type.googleapis.com/envoy.extensions.upstreams.http.v3.HttpProtocolOptions
                explicit_http_config:
                    http_protocol_options: {}
                upstream_http_protocol_options:
                    auto_san_validation: true
                    auto_sni: true
    listeners:
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 10000
          default_filter_chain:
            filters:
                - name: envoy.filters.network.tcp_proxy
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.tcp_proxy.v3.TcpProxy
                    cluster: deny_cluster
                    stat_prefix: egress_deny
          filter_chains:
            - filter_chain_match:
                server_names:
                    - stream.anthropic.com
                transport_protocol: tls
              filters:
                - name: envoy.filters.network.http_connection_manager
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: '%METADATA(ROUTE:clawker:action)%'
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    method: '%REQ(:METHOD)%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: http
                                    network.protocol.version: '%PROTOCOL%'
                                    network.transport: tcp
                                    path: '%REQ(:PATH)%'
                                    req_duration_ms: '%REQUEST_DURATION%'
                                    resp_duration_ms: '%RESPONSE_DURATION%'
                                    resp_tx_duration_ms: '%RESPONSE_TX_DURATION%'
                                    response_code: '%RESPONSE_CODE%'
                                    response_code_details: '%RESPONSE_CODE_DETAILS%'
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: '%REQUESTED_SERVER_NAME%'
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "true"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                                    upstream_transport_failure_reason: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    user_agent: '%REQ(USER-AGENT)%'
                    codec_type: AUTO
                    common_http_protocol_options:
                        headers_with_underscores_action: REJECT_REQUEST
                    http_filters:
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    http2_protocol_options:
                        allow_connect: true
                        max_concurrent_streams: 100
                    merge_slashes: true
                    normalize_path: true
                    path_with_escaped_slashes_action: UNESCAPE_AND_REDIRECT
                    route_config:
                        name: http_egress_routes
                        virtual_hosts:
                            - domains:
                                - stream.anthropic.com
                                - stream.anthropic.com:443
                              name: stream_anthropic_com_443
                              response_headers_to_add:
                                - header:
                                    key: alt-svc
                                    value: h3=":443"; ma=86400
                              routes:
                                - match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: allowed
                                  route:
                                    cluster: tls_stream_anthropic_com_443
                                    timeout: 0s
                                    upgrade_configs:
                                        - upgrade_type: websocket
                            - domains:
                                - '*'
                              name: deny_all
                              routes:
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Forbidden
                                    status: 403
                                  match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: denied
                    stat_prefix: http_egress
              transport_socket:
                name: envoy.transport_sockets.tls
                typed_config:
                    '@type': type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.DownstreamTlsContext
                    common_tls_context:
                        alpn_protocols:
                            - h2
                            - http/1.1
                        tls_certificates:
                            - certificate_chain:
                                filename: /etc/envoy/certs/stream.anthropic.com-cert.pem
                              private_key:
                                filename: /etc/envoy/certs/stream.anthropic.com-key.pem
          listener_filters:
            - name: envoy.filters.listener.tls_inspector
              typed_config:
                '@type': type.googleapis.com/envoy.extensions.filters.listener.tls_inspector.v3.TlsInspector
          name: egress
        - address:
            socket_address:
                address: 0.0.0.0
                port_value: 10000
                protocol: UDP
          filter_chains:
            - filter_chain_match:
                server_names:
                    - stream.anthropic.com
              filters:
                - name: envoy.filters.network.http_connection_manager
                  typed_config:
                    '@type': type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                    access_log:
                        - name: envoy.access_loggers.stdout
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                            log_format:
                                json_format:
                                    action: '%METADATA(ROUTE:clawker:action)%'
                                    bytes_received: '%BYTES_RECEIVED%'
                                    bytes_sent: '%BYTES_SENT%'
                                    client.address: '%DOWNSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    duration_ms: '%DURATION%'
                                    listener_ip: '%DOWNSTREAM_LOCAL_ADDRESS_WITHOUT_PORT%'
                                    method: '%REQ(:METHOD)%'
                                    network.peer.address: '%UPSTREAM_REMOTE_ADDRESS_WITHOUT_PORT%'
                                    network.peer.port: '%UPSTREAM_REMOTE_PORT%'
                                    network.protocol.name: http
                                    network.protocol.version: '%PROTOCOL%'
                                    network.transport: quic
                                    path: '%REQ(:PATH)%'
                                    req_duration_ms: '%REQUEST_DURATION%'
                                    resp_duration_ms: '%RESPONSE_DURATION%'
                                    resp_tx_duration_ms: '%RESPONSE_TX_DURATION%'
                                    response_code: '%RESPONSE_CODE%'
                                    response_code_details: '%RESPONSE_CODE_DETAILS%'
                                    response_flags: '%RESPONSE_FLAGS%'
                                    server.address: '%REQUESTED_SERVER_NAME%'
                                    tls.cipher: '%DOWNSTREAM_TLS_CIPHER%'
                                    tls.established: "true"
                                    tls.protocol.version: '%DOWNSTREAM_TLS_VERSION%'
                                    upstream_bytes_received: '%UPSTREAM_WIRE_BYTES_RECEIVED%'
                                    upstream_bytes_sent: '%UPSTREAM_WIRE_BYTES_SENT%'
                                    upstream_tls_cipher: '%UPSTREAM_TLS_CIPHER%'
                                    upstream_tls_version: '%UPSTREAM_TLS_VERSION%'
                                    upstream_transport_failure_reason: '%UPSTREAM_TRANSPORT_FAILURE_REASON%'
                                    user_agent: '%REQ(USER-AGENT)%'
                    codec_type: HTTP3
                    common_http_protocol_options:
                        headers_with_underscores_action: REJECT_REQUEST
                    http_filters:
                        - name: envoy.filters.http.router
                          typed_config:
                            '@type': type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
                    http2_protocol_options:
                        allow_connect: true
                        max_concurrent_streams: 100
                    http3_protocol_options:
                        allow_extended_connect: true
                    merge_slashes: true
                    normalize_path: true
                    path_with_escaped_slashes_action: UNESCAPE_AND_REDIRECT
                    route_config:
                        name: http_egress_routes
                        virtual_hosts:
                            - domains:
                                - stream.anthropic.com
                                - stream.anthropic.com:443
                              name: stream_anthropic_com_443
                              routes:
                                - match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: allowed
                                  route:
                                    cluster: tls_stream_anthropic_com_443
                                    timeout: 0s
                                    upgrade_configs:
                                        - upgrade_type: websocket
                            - domains:
                                - '*'
                              name: deny_all
                              routes:
                                - direct_response:
                                    body:
                                        inline_string: |
                                            Forbidden
                                    status: 403
                                  match:
                                    prefix: /
                                  metadata:
                                    filter_metadata:
                                        clawker:
                                            action: denied
                    stat_prefix: http_egress
              transport_socket:
                name: envoy.transport_sockets.quic
                typed_config:
                    '@type': type.googleapis.com/envoy.extensions.transport_sockets.quic.v3.QuicDownstreamTransport
                    downstream_tls_context:
                        common_tls_context:
                            tls_certificates:
                                - certificate_chain:
                                    filename: /etc/envoy/certs/stream.anthropic.com-cert.pem
                                  private_key:
                                    filename: /etc/envoy/certs/stream.anthropic.com-key.pem
          name: egress_quic
          udp_listener_config:
            downstream_socket_config:
                prefer_gro: true
            quic_options: {}
